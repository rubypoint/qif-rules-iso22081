            <xs:annotation>
              <xs:documentation>
                The optional SecondCompositeSegmentPositionItem
                gives information about the second segment of a
                composite frame position characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ThirdCompositeSegmentPositionItem"
                      type="CompositeSegmentPositionItemType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ThirdCompositeSegmentPositionItem
                gives information about the third segment of a
                composite frame position characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FourthCompositeSegmentPositionItem"
                      type="CompositeSegmentPositionItemType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FourthCompositeSegmentPositionItem
                gives information about the fourth segment of a
                composite frame position characteristic.
