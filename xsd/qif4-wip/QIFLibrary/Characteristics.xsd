  <xs:complexType name="WeldOneSideParametersBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract WeldOneSideParametersBaseType defines the base
        container of one-sided welding parameters.
      </xs:documentation>
