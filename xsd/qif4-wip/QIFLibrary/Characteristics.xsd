              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Length"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Length element specifies the length of a weld.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Pitch"
                      type="LinearValueType"
