  <xs:complexType name="RunoutCharacteristicItemBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract RunoutCharacteristicItemBaseType is the base type
        that defines a runout characteristic item.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="GeometricCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="RunoutCharacteristicDefinitionBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract RunoutCharacteristicDefinitionBaseType is the base
        type that defines a runout characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="GeometricCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="ToleranceValue"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The ToleranceValue element is the tolerance of the
                runout characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ToleranceDualValue"
                      type="LinearDualValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ToleranceDualValue element is the dual
                tolerance value of the runout characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DatumReferenceFrameId"
                      type="QIFReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DatumReferenceFrameId element is the QIF id of
                the datum reference frame of the runout characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TangentPlane"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TangentPlane element indicates whether the
                characteristic is evaluated with a tangent plane: "true"
                for tangent plane, "false" or not present for no tangent
                plane.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="RunoutCharacteristicNominalBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract RunoutCharacteristicNominalBaseType is the base type
        that defines a unique runout characteristic nominal.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="GeometricCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="RunoutCharacteristicMeasurementBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract RunoutCharacteristicMeasurementBaseType is the base
        type that defines the results of a measured runout characteristic
        evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="GeometricCharacteristicMeasurementBaseType">
        <xs:sequence>
          <xs:element name="DatumsOk"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DatumsOk element specifies whether the datum
                features passed all their associated characteristic
                evaluations. The element is set to "true" for passed all,
                is set to "false" for did not pass all, and is not present
                if the status of the datum features is unknown.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

