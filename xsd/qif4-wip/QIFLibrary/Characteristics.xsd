      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="OrientationCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ParallelismCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The ParallelismCharacteristicDefinitionType defines information
        that can be common to more than one parallelism characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="OrientationCharacteristicDefinitionBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ParallelismCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
