  <xs:complexType name="InternalEdgeFillCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The InternalEdgeFillCharacteristicDefinitionType defines
        an edge treatment definition for a treatment that allows extra
        material on an internal edge. The right face is the face on
        the right when traveling in the direction of travel on the
        outside of the edge. The left face is the other face adjoining
        the edge. If an instance of this type is referenced by an
        InternalEdgeFillCharacteristicNominal element that has no
        LoopFeatureId, direction of travel is ambiguous. In that case
        the smaller of the RightFaceFillDistance and LeftFaceFillDistance
        applies to both faces, if either one is given.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="ToleranceValue"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The ToleranceValue element is the linear tolerance of
                the RightFaceFillDistance, LeftFaceFillDistance and
                MaxFillRadius.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RightFaceFillDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional RightFaceFillDistance element is the
                distance the fill shall extend on the right face, measured
                along the face and normal to the edge.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LeftFaceFillDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LeftFaceFillDistance element is the
                distance the fill shall extend on the left face, measured
                along the face and normal to the edge.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxFillRadius"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxFillRadius element is a radius
                outside of which no material shall remain.
                Specifically, at each point on the edge, no edge
                material shall remain on a plane normal to the edge
                outside a circular arc in that plane, with its center
                outside the edge, and of the given radius, that either
                (1) is tangent to both sides at points not farther
                from the edge than the extension value for each face
                (if that is possible), or (2) if it is not possible to
                locate the arc as in 1, passes through the extension
                points on the faces.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ChamferLimit"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ChamferLimit element, if used and set to
                true, means no material shall extend from the edge outside
                what a flat chamfer would leave if it chamfered to the
                fill distance on both faces.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TargetOrMaximum"
                      type="TargetOrMaximumEnumType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TargetOrMaximum element, if used
                indicates whether the RightFaceFillDistance,
                LeftFaceFillDistance, and MaxFillRadius are target
                amounts or maximum amounts. If this element is not
                used, the fill amounts are targets. For a minimal
                edge fill, this element shall be set to MAXIMUM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="InternalEdgeFillCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The InternalEdgeFillCharacteristicNominalType
        defines an edge treatment nominal for a treatment
        that allows additional material on an internal edge.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="InternalEdgeFillCharacteristicItemType">
    <xs:annotation>
      <xs:documentation>
        The InternalEdgeFillCharacteristicItemType
        defines an edge treatment item for a treatment
