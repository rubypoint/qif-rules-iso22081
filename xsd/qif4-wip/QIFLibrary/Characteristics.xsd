  <xs:simpleType name="DiameterRadiusEnumType">
    <xs:annotation>
      <xs:documentation>
        The DiameterRadiusEnumType enumerates values that disambiguate
        a diameter or radius characteristic applied to a torus or
        ellipse. The values INSIDE and OUTSIDE apply only to a torus
        or toroidal segment and refer, respectively, to the hole in
        the middle of the torus and the equator of the torus.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:NMTOKEN">
      <xs:enumeration value="MINOR"/>
      <xs:enumeration value="MAJOR"/>
      <xs:enumeration value="INSIDE"/>
      <xs:enumeration value="OUTSIDE"/>
    </xs:restriction>
