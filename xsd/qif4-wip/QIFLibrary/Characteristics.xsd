<!-- START CHARACTERISTIC ASPECT LIST TYPES -->

  <xs:complexType name="CharacteristicsType">
    <xs:annotation>
      <xs:documentation>
        The CharacteristicsType includes:
        - the id of the standard to which characteristics conform
        - lists of aspects of characteristics (definitions, nominals,
          and items) for many specific types of characteristic
        - an optional list of default characteristics definitions for
          many specific types of characteristic
        - an optional list of default tolerance definitions
        - an optional list of characteristic groups
        - an optional list of simultaneous requirements groups
        - an optional list of verification plan requirements
        - an optional list of user-defined criticality levels
        - an optional list of user-defined criticality categories
        Characteristic measurements are given elsewhere in the QIF model.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="StandardOrSectionId"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional StandardOrSectionId element is the QIF id of
            a standard or specification, or a section of a standard or
            specification, against which the characteristics are to be
            evaluated. This value may be overridden by a value in a
            characteristic nominal, characteristic item, or
            characteristic measurement.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="CharacteristicDefinitions"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CharacteristicDefinitions element is a list of
            characteristic definitions. If this element is not present,
            the CharacteristicNominals element shall not be present.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="DefaultCharacteristicDefinitions"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DefaultCharacteristicDefinitions element is a list
            of default or "unless otherwise specified" characteristic
            definitions.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="DefaultToleranceDefinitions"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DefaultToleranceDefinitions element is a list of
            default or "unless otherwise specified" tolerance definitions
            which allow a tolerance definition to be shared among
            characteristic definitions of different types.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="CharacteristicNominals"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CharacteristicNominals element is a list of
            characteristic nominals. If this list is not present, any
            characteristic items shall reference characteristic
            nominals in an external QIF file.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="CharacteristicItems"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CharacteristicItems element is a list of
            characteristic items. This is the entry point in QIF for the
            information contained in a bill of characteristics (BOC).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="CharacteristicGroups"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CharacteristicGroups element is a list of
            characteristic groups.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="SimultaneousRequirementGroups"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional SimultaneousRequirementGroups element is a list
            of simultaneous requirement groups.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="VerificationPlanRequirements"
                  type="VerificationPlanRequirementsListType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional VerificationPlanRequirements element is a list
            of verification plan requirements.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UserCriticalityLevels"
                  type="UserCriticalityLevelsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional UserCriticalityLevels element is a list
            of user-defined criticality levels.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UserCriticalityCategories"
                  type="UserCriticalityCategoriesType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional UserCriticalityCategories element is a list
            of user-defined criticality categories.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="MeasuredCharacteristicsType">
    <xs:annotation>
      <xs:documentation>
        The MeasuredCharacteristicsType contains a list of characteristic
        measurements and optionally the status of characteristic group
        evaluations.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="CharacteristicMeasurements"
                  type="CharacteristicMeasurementsType">
        <xs:annotation>
          <xs:documentation>
            The CharacteristicMeasurements element is a list of
            characteristic measurements.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CharacteristicGroupStatuses"
                  type="CharacteristicGroupStatusesType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CharacteristicGroupStatuses element is a list of
            characteristic group statuses.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:element name="MeasuredCharacteristics"
              type="MeasuredCharacteristicsType">
    <xs:annotation>
      <xs:documentation>
        The global MeasuredCharacteristics element is a list of
        characteristic measurements.
      </xs:documentation>
    </xs:annotation>

    <xs:key name="WeldFromCompoundCharacteristicMeasurementIdKey">
      <xs:annotation>
        <xs:documentation>
          The WeldFromCompoundCharacteristicMeasurementIdKey collects all
          QIF ids of all weld characteristic measurements that may be
          referenced by the compound weld measurement.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:CharacteristicMeasurements
              /t:WeldFilletCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldPlugCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldSlotCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldSpotCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldStudCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldSeamCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldSurfacingCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldEdgeCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldSquareCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldBevelCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldVCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldUCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldJCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldFlareVCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldFlareBevelCharacteristicMeasurement
             | t:CharacteristicMeasurements
              /t:WeldScarfCharacteristicMeasurement"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="WeldCompoundCharacteristicMeasurementWeldCharacteristicKeyref"
      refer="WeldFromCompoundCharacteristicMeasurementIdKey">
      <xs:selector
        xpath="t:CharacteristicMeasurements
              /t:WeldCompoundCharacteristicMeasurement
              /t:WeldCharacteristicMeasurementIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>
  </xs:element>

  <xs:complexType name="CharacteristicItemsType">
    <xs:annotation>
      <xs:documentation>
        The CharacteristicItemsType defines a list of characteristic
        items.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="CharacteristicItem"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each CharacteristicItem element gives information about a
            characteristic item.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of characteristic items in
          this set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:element name="CharacteristicItems"
              type="CharacteristicItemsType">
    <xs:annotation>
      <xs:documentation>
        The global CharacteristicItems element is a list of
        characteristic items.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="CharacteristicGroup"
              type="CharacteristicGroupType">
    <xs:annotation>
      <xs:documentation>
        The global CharacteristicGroup element is the head of a
        substitution group. Any element that is a member of the group may
        be substituted for the CharacteristicGroup element anywhere the
        CharacteristicGroup element may be used in an instance file.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="CharacteristicGroupsType">
    <xs:annotation>
      <xs:documentation>
        The CharacteristicGroupsType defines a list of characteristic
        groups.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="CharacteristicGroup"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each CharacteristicGroup element gives information about a
            characteristic group. It is a way of relating characteristics
            based on common association. e.g. manufacturing, process, print
            callout.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of characteristic groups
