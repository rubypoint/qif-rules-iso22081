<!-- BEGIN STRAIGHTNESS CHARACTERISTIC TYPES -->

  <xs:complexType name="StraightnessDiametricalZoneType">
    <xs:annotation>
      <xs:documentation>
        The StraightnessDiametricalZoneType defines the shape of a
        tolerance zone as diametrical.
      </xs:documentation>
    </xs:annotation>
  </xs:complexType>

  <xs:complexType name="StraightnessNonDiametricalZoneType">
    <xs:annotation>
      <xs:documentation>
        The StraightnessNonDiametricalZoneType defines the shape of a
        tolerance zone as parallel lines.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ZoneOrientationVector"
                  type="UnitVectorType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ZoneOrientationVector element gives the
            orientation of the tolerance zone.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="StraightnessZoneShapeType">
    <xs:annotation>
      <xs:documentation>
        The StraightnessZoneShapeType defines the shape of tolerance zone
        for a straightness characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:annotation>
        <xs:documentation>
          This compositor provides a choice between a diametrical tolerance
          zone shape and a non-diametrical tolerance zone shape.
        </xs:documentation>
      </xs:annotation>
      <xs:element name="DiametricalZone"
                  type="StraightnessDiametricalZoneType">
        <xs:annotation>
          <xs:documentation>
            The DiametricalZone element is present when the straightness
            characteristic feature control frame contains a diameter symbol
            modifying the tolerance value.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NonDiametricalZone"
                  type="StraightnessNonDiametricalZoneType">
        <xs:annotation>
          <xs:documentation>
            The NonDiametricalZone element is present when the straightness
            characteristic feature control frame does not contain a
            diameter symbol modifying the tolerance value.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="StraightnessCharacteristicItemType">
    <xs:annotation>
      <xs:documentation>
        The StraightnessCharacteristicItemType defines a straightness
        characteristic item.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="FormCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="StraightnessToleranceType">
    <xs:annotation>
      <xs:documentation>
        The StraightnessToleranceType provides a choice between a
        simple straightness tolerance (with an optional dual value and
        an optional second tier per-unit-length tolerance) and a
        per-unit-length tolerance.
      </xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="ToleranceValueSelector"
                  type="LinearAndPerUnitLengthToleranceType">
        <xs:annotation>
          <xs:documentation>
            The ToleranceValueSelector element is the choice of a
            simple straightness tolerance with an optional dual
            value and an optional per-unit-length tolerance.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ToleranceZonePerUnitLength"
                  type="ToleranceZonePerUnitLengthType">
        <xs:annotation>
          <xs:documentation>
            The ToleranceZonePerUnitLength element is the choice of
            only a per-unit-length tolerance of the straightness
            characteristic.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="StraightnessCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The StraightnessCharacteristicDefinitionType defines information
        that can be common to more than one straightness characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="FormCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="StraightnessTolerance"
                      type="StraightnessToleranceType">
            <xs:annotation>
              <xs:documentation>
                The StraightnessTolerance element provides a choice
                between a simple straightness tolerance (with an
                optional second tier per-unit-length tolerance) and a
                per-unit-length tolerance.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaterialCondition"
                      type="MaterialModifierEnumType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaterialCondition element is the material
                condition modifier for a feature of size such as when
                applied to the axis of a cylinder.
              </xs:documentation>
              <xs:documentation>
                ASME Y14.5-2009 - 5.4.1.2
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SizeCharacteristicDefinitionId"
                      type="QIFReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional SizeCharacteristicDefinitionId element is the
                QIF id of the associated feature size characteristic used
                to derive bonus tolerance for maximum and least material
                conditions.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ZoneShape"
                      type="StraightnessZoneShapeType">
            <xs:annotation>
              <xs:documentation>
                The ZoneShape element describes the shape of the tolerance
                zone.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaximumToleranceValue"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaximumToleranceValue element is the maximum
                tolerance value in cases where bonus is available.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaximumToleranceDualValue"
                      type="LinearDualValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaximumToleranceDualValue element is the
                dual maximum tolerance value in cases where bonus is
                available.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="StraightnessCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The StraightnessCharacteristicNominalType defines a unique
        straightness characteristic nominal.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="FormCharacteristicNominalBaseType">
        <xs:sequence>
          <xs:element name="DirectionCurveId"
                      type="QIFReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DirectionCurveId element is the QIF
                id of the curve feature.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="StraightnessCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The StraightnessCharacteristicMeasurementType defines the results
        of a measured straightness characteristic evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="FormCharacteristicMeasurementBaseType">
        <xs:sequence>
          <xs:element name="Bonus"
                      type="MeasuredLinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Bonus element is the size of the applied
                bonus.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxStraightness"
                      type="MeasuredLinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxStraightness element is the measured overall
                feature straightness when a per-unit-length characteristic
                is used.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ZoneOrientation"
                      type="MeasuredUnitVectorType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ZoneOrientation element is the measured
                orientation of the plane (the plane normal) in which
                parallel-line shaped tolerance zone lies.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ZoneLine"
                      type="MeasuredZoneAxisType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ZoneLine element is the measured mid-line of
                the parallel-line or cylinder shaped tolerance zone.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

<!-- END STRAIGHTNESS CHARACTERISTIC TYPES -->

<!-- BEGIN EDGE TREATMENT CHARACTERISTIC TYPES -->

<!--
    In this edge treatment model, an edge is a line on a body where the
    surface is not smooth (C1 continuous). Many topological edges are
    on smooth portions of a surface; this model does not apply to such
    edges. However, all edges to which this model applies are expected
    to be topological edges.
-->

  <xs:complexType name="EdgeTreatmentCharacteristicDefinitionBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract EdgeTreatmentCharacteristicDefinitionBaseType
        is the base type that defines an edge treatment definition.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="FormCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="Smooth"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Smooth element, if used and set to true,
                means that the surface of the edge treatment shall
                be smooth (i.e. C1 continuous at every interior point).
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="EdgeTreatmentCharacteristicNominalBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract EdgeTreatmentCharacteristicNominalBaseType is the
        base type that defines a nominal edge treatment.
          + If the inherited optional FeatureNominalIds element is not
          used, the edge treatment applies to all external edges or all
          internal edges (depending on the derived type) that do not
          have a more specific edge treatment applied.
          + If the inherited optional FeatureNominalIds element is used,
          it shall contain a single entry that is the Id of an
          OtherShapeFeatureNominal whose EntityInternalIds has a
          single entry that is the id of a topological loop containing
          the edges to be treated.
          + Also if the FeatureNominalIds element is used, the edge
          treatment applies to all edges on the topological loop between
          the StartPoint and the EndPoint, traversed in the direction of
          the loop, or opposite that direction if the turned element
          exists and is true. 
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="FormCharacteristicNominalBaseType">
        <xs:sequence>
          <xs:element name="StartPoint"
                      type="PointType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StartPoint element is the point on the
                loop where the edge treatment begins. If the
                FeatureNominalIds element is not used, no StartPoint
                should be given, and if given shall be ignored. If
                the FeatureNominalIds element is used, and no
                StartPoint is given, the treatment applies to all
                external edges or all internal edges of the loop,
                depending on the derived type.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="EndPoint"
                      type="PointType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional EndPoint element is the point on the loop
                where the edge treatment ends. If the FeatureNominalIds
                element is not used, no EndPoint should be given, and if
                given shall be ignored. If the FeatureNominalIds
                element is used, and no EndPoint is given, the treatment
                applies to all external edges or all internal edges of the
                loop, depending on the derived type. If the EndPoint is
                the same as the StartPoint, the treatment applies to all
                external edges or all internal edges of the loop, depending
                on the derived type.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
        <xs:attribute name="turned"
                      type="xs:boolean"
                      default="0">
          <xs:annotation>
            <xs:documentation>
              The optional turned attribute shows if the direction of
              travel from the StartPoint to the EndPoint is
              reversed from the orientation of the loop. If the value
              is true, the direction of travel is opposite the
              loop orientation.  If the value is false, the direction
              of travel is the same as the loop orientation.
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="EdgeTreatmentCharacteristicItemBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract EdgeTreatmentCharacteristicItemBaseType is the
        base type that defines an edge treatment item. 
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="FormCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="EdgeTreatmentCharacteristicMeasurementBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract EdgeTreatmentCharacteristicMeasurementBaseType is the
        base type that defines an edge treatment measurement. 
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="FormCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ExternalEdgeReductionCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The ExternalEdgeReductionCharacteristicDefinitionType defines an
        edge treatment definition for a treatment that reduces an
        external edge. The right face is the face on the right when
        traveling in the direction of travel on the outside of the
        edge. The left face is the other face adjoining the edge. If
        both face reduction elements are omitted, any flash or burrs
        shall be removed while leaving the edge otherwise unchanged.
        If an instance of this type is referenced by a
        ExternalEdgeReductionCharacteristicNominal element that has no
        FeatureNominalIds, direction of travel is ambiguous. In that
        case the RightFaceReduction applies to both faces adjoining
        the edge and any LeftFaceReduction that is given shall be
        ignored.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="ToleranceValue"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The ToleranceValue element is the linear tolerance of
                the RightFaceReduction, LeftFaceReduction and
                MinReductionRadius.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RightFaceReduction"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional RightFaceReduction element is the
                reduction on the right face, measured along the face and
                normal to the edge. The value shall be positive or zero.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LeftFaceReduction"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LeftFaceReduction element is the
                reduction on the left face, measured along the face and
                normal to the edge. The value shall be positive or zero.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MinReductionRadius"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MinReductionRadius element is the minimum
                radius of reduction specified in ASME AED-1-2023. At
                each point on the edge, no edge material shall remain
                on a plane normal to the edge outside a circular arc
                in that plane, with its center inside the edge, and of
                the given radius, that either (1) is tangent to both
                sides at points not farther the edge than the
                reduction value for each face (if that is possible),
                or (2) if it is not possible to locate the arc as in
                1, passes through the reduction points on the faces.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ChamferLimit"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ChamferLimit element, if used and set to true,
                means no material shall be removed from the edge inside
                what a flat chamfer would remove if it chamfered to the
                reduction limit on both faces. For conforming to
                ASME AED-1-2023, this element shall be set to true.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TargetOrMaximum"
                      type="TargetOrMaximumEnumType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TargetOrMaximum element, if used
                indicates whether the RightFaceReduction,
                LeftFaceReduction, and MinReductionRadius are target
                amounts or maximum amounts. If this element is not
                used, the reduction amounts are targets. For a minimal
                edge break, this element shall be set to MAXIMUM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ExternalEdgeReductionCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The ExternalEdgeReductionCharacteristicNominalType
        defines an edge treatment nominal for a treatment
        that reduces an external edge.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ExternalEdgeReductionCharacteristicItemType">
