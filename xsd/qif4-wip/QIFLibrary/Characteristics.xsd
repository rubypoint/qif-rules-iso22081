<!-- DEFINE THE CHARACTERISTICS ELEMENT -->

  <xs:element name="Characteristics"
              type="CharacteristicsType">
    <xs:annotation>
      <xs:documentation>
        The global Characteristics element contains:
        - the id of the standard to which characteristics conform
        - lists of aspects of characteristics (definitions, nominals,
          and items) for many specific types of characteristic
        - an optional list of default characteristics definitions for
          many specific types of characteristic
        - an optional list of default tolerance definitions
        - an optional list of characteristic groups
        - an optional list of simultaneous requirements groups
        - an optional list of verification plan requirements
        - an optional list of user-defined criticality levels
        - an optional list of user-defined criticality categories
        Characteristic measurements are given elsewhere in the QIF model.
      </xs:documentation>
    </xs:annotation>

<!-- START NOMINAL TO DEFINITION KEY/KEYREF PAIRS FOR CHARACTERISTICS -->

    <xs:keyref name="AngleCharacteristicNominalToDefinitionKeyref"
      refer="AngleCharacteristicDefinitionKey">
      <xs:annotation>
        <xs:documentation>
          The AngleCharacteristicNominalToDefinitionKeyref requires that
          the DefinitionId of an AngleCharacteristicNominal be present
          in the AngleCharacteristicDefinitionKey. All other
          CharacteristicNominalToDefinitionKeyrefs are similar.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:CharacteristicNominals/t:AngleCharacteristicNominal"/>
      <xs:field xpath="t:CharacteristicDefinitionId"/>
    </xs:keyref>

    <xs:key name="AngleCharacteristicDefinitionKey">
      <xs:annotation>
        <xs:documentation>
          The AngleCharacteristicDefinitionKey collects all QIF ids of
          AngleCharacteristicDefinitions. All other
          CharacteristicDefinitionKeys are similar.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:CharacteristicDefinitions/t:AngleCharacteristicDefinition"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="AngleBetweenCharacteristicNominalToDefinitionKeyref"
      refer="AngleBetweenCharacteristicDefinitionKey">
      <xs:selector
        xpath="t:CharacteristicNominals/t:AngleBetweenCharacteristicNominal"/>
