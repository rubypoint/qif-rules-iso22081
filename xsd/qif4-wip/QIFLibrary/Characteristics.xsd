      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="OrientationCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="PerpendicularityCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
