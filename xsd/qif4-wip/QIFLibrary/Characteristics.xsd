      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="InternalEdgeFillCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The InternalEdgeFillCharacteristicMeasurementType
        defines an edge treatment measurement for a treatment
        that allows additional material on an internal edge.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="InternalEdgeReductionCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The InternalEdgeReductionCharacteristicDefinitionType defines
        an edge treatment definition for a treatment that reduces
        an internal edge. The right face is the face on
        the right when traveling in the direction of travel on the
        outside of the edge. The left face is the other face adjoining
        the edge. If an instance of this type is referenced by an
        InternalEdgeReductionCharacteristicNominal element that has no
        LoopFeatureId, direction of travel is ambiguous. In that case
        the smaller of the RightFaceReduction and LeftFaceReduction
        applies to both faces adjoining the edge, if either is given.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="ToleranceValue"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The ToleranceValue element is the linear tolerance of
                the RightFaceReduction, LeftFaceReduction and
                MaxReductionRadius.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RightFaceReduction"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional RightFaceReduction element is the
                maximum allowed reduction of the right face. The
                value shall be positive or zero. If this element is
                not used, the maximum allowed reduction of the
                right face is the MaxReductionRadius.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LeftFaceReduction"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LeftFaceReduction element is the
                maximum allowed reduction of the left face. The
                value shall be positive or zero. If this element is
                not used, the maximum allowed reduction of the
                left face is the MaxReductionRadius.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxReductionRadius"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The MaxReductionRadius element is a radius outside of
                which no material shall be removed.  Specifically, at
                each point on the edge, no material shall be removed
                on a plane normal to the edge outside a circular arc
                of the given radius in that plane, with its center on
                the edge.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TargetOrMaximum"
                      type="TargetOrMaximumEnumType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TargetOrMaximum element, if used
                indicates whether the RightFaceReduction,
                LeftFaceReduction, and MaxReductionRadius are target
                amounts or maximum amounts. If this element is not
                used, the reduction amounts are targets.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="InternalEdgeReductionCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The InternalEdgeReductionCharacteristicNominalType
        defines an edge treatment nominal for a treatment
        that reduces an internal edge.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="InternalEdgeReductionCharacteristicItemType">
    <xs:annotation>
