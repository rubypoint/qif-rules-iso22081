                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CoordinateSystemId element is the QIF id of
                the coordinate system in which this characteristic is
                evaluated.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MeasurementDirective"
                      type="MeasurementDirectiveType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MeasurementDirective element modifies the
                characteristic evaluation to be the average, minimum or
                maximum angle between two features. For example, the angle
                from an origin to two circles can be from their centers or
                from their closest or furthest tangents.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Vertex"
                      type="PointType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Vertex element is the point of intersection of
