              <xs:documentation>
                The optional SecondCompositeSegmentSymmetryMeasurement
                gives information about the second segment of a
                measured composite frame symmetry characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ThirdCompositeSegmentSymmetryMeasurement"
                      type="CompositeSegmentSymmetryMeasurementType"
