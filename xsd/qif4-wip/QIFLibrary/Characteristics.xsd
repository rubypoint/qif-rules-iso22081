                zone.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ConcentricityCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
