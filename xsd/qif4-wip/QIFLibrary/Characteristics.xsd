          <xs:element name="Value"
                      type="MeasuredAngularValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Value element is the measured value.
                Where parts are checked using hard gages, it is anticipated
                that the Value will not be populated.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxValue"
                      type="MeasuredAngularValueType"
                      minOccurs="0">
            <xs:annotation>
