      <xs:extension base="EdgeTreatmentCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ExternalEdgeReductionCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The ExternalEdgeReductionCharacteristicMeasurementType
        defines an edge treatment measurement for a treatment
        that reduces an external edge.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ExternalEdgeGrowthCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The ExternalEdgeGrowthCharacteristicDefinitionType defines an
        edge treatment definition for a treatment that allows extra
        material (e.g., flash) on an external edge.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="ToleranceValue"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The ToleranceValue element is the linear tolerance of
                the RightFaceGrowthDistance, LeftFaceGrowthDistance,
                and GrowthRadius
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RightFaceGrowthDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional RightFaceGrowthDistance element is the maximum
                distance the growth shall extend on the right face, measured
                along the face and normal to the edge.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LeftFaceGrowthDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LeftFaceGrowthDistance element is the maximum
                distance the growth shall extend on the left face, measured
                along the face and normal to the edge.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="GrowthRadius"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional GrowthRadius element is the radius of a circle
                with its center at any point on the edge in a plane normal
                to the edge within which any extra material on the plane
                shall lie. Where edges meet at a corner, any material not
                inside such a circle shall lie inside a sphere with its
                center at the corner point whose radius is the smallest
                of the growth radii of the edges meeting at the corner.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TargetOrMaximum"
                      type="TargetOrMaximumEnumType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TargetOrMaximum element, if used
                indicates whether the RightFaceGrowthDistance,
                LeftFaceGrowDistance, and GrowthRadius are target amounts
                or maximum amounts. If this element is not used, the
                growth amounts are targets.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:simpleType name="TargetOrMaximumEnumType">
    <xs:annotation>
      <xs:documentation>
        The TargetOrMaximumEnumType enumerates values that describe
        whether certain values are targets (if the TARGET value is used)
        or maxima (if the MAXIMUM value is used).
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:NMTOKEN">
      <xs:enumeration value="TARGET"/>
      <xs:enumeration value="MAXIMUM"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="ExternalEdgeGrowthCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The ExternalEdgeGrowthCharacteristicNominalType
        defines an edge treatment nominal for a treatment
        that allows extra material on an external edge.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ExternalEdgeGrowthCharacteristicItemType">
    <xs:annotation>
