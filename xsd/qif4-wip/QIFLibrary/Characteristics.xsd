                gives information about the second segment of a
                composite frame symmetry characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ThirdCompositeSegmentSymmetryItem"
                      type="CompositeSegmentSymmetryItemType"
                      minOccurs="0">
