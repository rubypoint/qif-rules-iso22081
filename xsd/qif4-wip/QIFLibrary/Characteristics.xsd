      <xs:documentation>
        The CircularRunoutCharacteristicNominalType defines a unique
        circular runout characteristic nominal.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="RunoutCharacteristicNominalBaseType">
        <xs:sequence>
          <xs:element name="ZoneDirection"
                      type="UnitVectorType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ZoneDirection element gives the direction for
                the tolerance zone width when it is not normal to the
                product surface.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ProfileCurveId"
                      type="QIFReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ProfileCurveId element is the QIF
                id of the curve feature.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="CircularRunoutCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The CircularRunoutCharacteristicMeasurementType defines the results
        of a measured circular runout characteristic evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="RunoutCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="TotalRunoutCharacteristicItemType">
    <xs:annotation>
      <xs:documentation>
        The TotalRunoutCharacteristicItemType defines a total runout
        characteristic item.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="RunoutCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="TotalRunoutCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The TotalRunoutCharacteristicDefinitionType defines information
        that can be common to more than one total runout characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="RunoutCharacteristicDefinitionBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="TotalRunoutCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The TotalRunoutCharacteristicNominalType defines a unique total
        runout characteristic nominal.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="RunoutCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="TotalRunoutCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The TotalRunoutCharacteristicMeasurementType defines a total runout
        characteristic evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="RunoutCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

<!-- END RUNOUT CHARACTERISTIC TYPES -->

<!-- BEGIN PROFILE CHARACTERISTIC TYPES -->

  <xs:complexType name="ProfileCharacteristicItemBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract ProfileCharacteristicItemBaseType is the base type
        that defines a profile characteristic item.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="GeometricCharacteristicItemBaseType">
        <xs:sequence>
          <xs:element name="SecondCompositeSegmentProfileItem"
                      type="CompositeSegmentProfileItemType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional SecondCompositeSegmentProfileItem
                gives information about the second segment of a
                composite frame profile characteristic item.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ThirdCompositeSegmentProfileItem"
                      type="CompositeSegmentProfileItemType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ThirdCompositeSegmentProfileItem
                gives information about the third segment of a
                composite frame profile characteristic item.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FourthCompositeSegmentProfileItem"
                      type="CompositeSegmentProfileItemType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FourthCompositeSegmentProfileItem
                gives information about the fourth segment of a
                composite frame profile characteristic item.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="OuterDispositionWithDualType">
    <xs:annotation>
      <xs:documentation>
        The OuterDispositionWithDualType provides an OuterDisposition
        with an optional DualOuterDisposition.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="OuterDisposition"
                  type="LinearValueType">
        <xs:annotation>
          <xs:documentation>
            The optional OuterDisposition element is the outer
            disposition of the profile characteristic's tolerance zone
            when the tolerance zone is not symmetric about or is offset
            from the nominal surface or curve. The value represents the
            upper tolerance limit when the tolerance zone is expressed as
            a bi-directional tolerance. For asymmetrically disposed
            tolerance zones it may range in value from zero when the
            tolerance zone is completely inside the part material, to the
            whole tolerance value when the tolerance zone is completely
            outside the part material. For offset tolerance zones it shall
            have a negative value for a tolerance zone offset inside the
            part material, or a positive value greater than the tolerance
            value for a tolerance zone offset outside the part material.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DualOuterDisposition"
                  type="LinearDualValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DualOuterDisposition element is the dual outer
            disposition of the profile characteristic's tolerance zone.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="UnequallyDisposedZoneWithDualType">
    <xs:annotation>
      <xs:documentation>
        The UnequallyDisposedZoneWithDualType provides an
        UnequallyDisposedZone with an optional DualUnequallyDisposedZone.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="UnequallyDisposedZone"
                  type="LinearValueType">
        <xs:annotation>
          <xs:documentation>
            (ISO specific UZ) The UnequallyDisposedZone element is the
            center of the profile characteristic's tolerance zone when
            the tolerance zone is not symmetric about or is offset
            from the nominal surface or curve. For asymmetrically
            disposed tolerance zones it has a positive value when the
            center of the tolerance zone is outside the part material,
            and a negative value when the center of the tolerance zone
            is inside the part material.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DualUnequallyDisposedZone"
                  type="LinearDualValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DualUnequallyDisposedZone element is the dual
            center of the profile characteristic's tolerance zone.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="OuterOrUnequalType">
    <xs:annotation>
      <xs:documentation>
        The OuterOrUnequalType provides a choice between the ASME
        Y14.5 and ISO 1101 implementations of unequal, unilateral
        or offset profile tolerance zones.
      </xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="OuterDispositionWithDual"
                  type="OuterDispositionWithDualType">
        <xs:annotation>
          <xs:documentation>
            The OuterDispositionWithDual element provides an
            OuterDisposition element with an optional
            DualOuterDisposition element.  The OuterDisposition
            element is the outer disposition of the profile
            characteristic's tolerance zone when the tolerance zone is
            not symmetric about or is offset from the nominal surface
            or curve. The value represents the upper tolerance limit
            when the tolerance zone is expressed as a bi-directional
            tolerance. For asymmetrically disposed tolerance zones it
            may range in value from zero when the tolerance zone is
            completely inside the part material, to the whole
            tolerance value when the tolerance zone is completely
            outside the part material. For offset tolerance zones it
            shall have a negative value for a tolerance zone offset
            inside the part material, or a positive value greater than
            the tolerance value for a tolerance zone offset outside
            the part material. The DualOuterDisposition element is the
            dual value of the OuterDisposition element.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UnequallyDisposedZoneWithDual"
                  type="UnequallyDisposedZoneWithDualType">
        <xs:annotation>
          <xs:documentation>
            (ISO specific UZ) The UnequallyDisposedZoneWithDual
            element provides an UnequallyDisposedZone element with an
            optional DualUnequallyDisposedZone element. The
            UnequallyDisposedZone element is the center of the profile
            characteristic's tolerance zone when the tolerance zone is
            not symmetric about or is offset from the nominal surface
            or curve. For asymmetrically disposed tolerance zones it
            has a positive value when the center of the tolerance zone
            is outside the part material, and a negative value when
            the center of the tolerance zone is inside the part
            material. The DualUnequallyDisposedZone element is the
            dual value of the UnequallyDisposedZone element.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="ProfileCharacteristicDefinitionBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract ProfileCharacteristicDefinitionBaseType is the base
        type that defines a profile characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="GeometricCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="ToleranceValue"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The ToleranceValue element is the tolerance of the
                profile characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ToleranceDualValue"
                      type="LinearDualValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ToleranceDualValue element is the dual
                tolerance value of the profile characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="OuterOrUnequal"
                      type="OuterOrUnequalType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional OuterOrUnequal element gives a choice
                between the ASME Y14.5 and ISO 1101 implementations of
                unequal, unilateral or offset profile tolerance zones.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="OffsetZone"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                (ISO specific OZ) The optional OffsetZone element when
                present and set to true indicates that the profile
                tolerance zone may be offset by any unspecified amount.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="VariableAngle"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                (ISO specific VA) The optional VariableAngle element when
                present and set to true indicates that the profile
                tolerance zone may be offset by an unspecified angular
                amount.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SecondCompositeSegmentProfileDefinition"
                      type="CompositeSegmentProfileDefinitionType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional SecondCompositeSegmentProfileDefinition
                gives information about the second segment of a
                composite frame profile characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ThirdCompositeSegmentProfileDefinition"
                      type="CompositeSegmentProfileDefinitionType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ThirdCompositeSegmentProfileDefinition
                gives information about the third segment of a
                composite frame profile characteristic. This element
                may be used only if the
                SecondCompositeSegmentProfileDefinition element is used.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FourthCompositeSegmentProfileDefinition"
                      type="CompositeSegmentProfileDefinitionType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FourthCompositeSegmentProfileDefinition
                gives information about the fourth segment of a
                composite frame profile characteristic. This element
                may be used only if the
                ThirdCompositeSegmentProfileDefinition element is used.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DatumReferenceFrameId"
                      type="QIFReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DatumReferenceFrameId element is the QIF id of
                the datum reference frame for the profile characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="OrientationOnly"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                (ISO specific greaterthan/lessthan) The optional
                OrientationOnly element when present and set to true
                signifies that the DRF associated with this profile
                characteristic controls only orientation degrees of
                freedom.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TangentPlane"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TangentPlane element indicates whether the
                characteristic is evaluated with a tangent plane: "true"
                for tangent plane, "false" or not present for no tangent
                plane.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DynamicProfile"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DynamicProfile element
                indicates whether the characteristic is applied with the
                ASME dynamic profile: "true" for dynamic profile,
                "false" or not present for no dynamic profile or not
                applicable.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ProfileCharacteristicNominalBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract ProfileCharacteristicNominalBaseType is the base type
        that defines a unique profile characteristic nominal.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="GeometricCharacteristicNominalBaseType">
        <xs:sequence>
          <xs:element name="TargetValue"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TargetValue element is a non-zero value to
                indicate a target value offset from the nominal surface or
                curve.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DualTargetValue"
                      type="LinearDualValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DualTargetValue element is a non-zero
                value to indicate the dual target value offset from
                the nominal surface or curve.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SecondCompositeSegmentProfileNominal"
                      type="CompositeSegmentProfileNominalType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional SecondCompositeSegmentProfileNominal element
                gives information about the second segment of a
                composite frame profile characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ThirdCompositeSegmentProfileNominal"
                      type="CompositeSegmentProfileNominalType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ThirdCompositeSegmentProfileNominal element
                gives information about the third segment of a
                composite frame profile characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FourthCompositeSegmentProfileNominal"
                      type="CompositeSegmentProfileNominalType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FourthCompositeSegmentProfileNominal element
                gives information about the fourth segment of a
                composite frame profile characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ProfileCharacteristicMeasurementBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract ProfileCharacteristicMeasurementBaseType is the base
        type that defines the results of a measured profile characteristic
        evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="GeometricCharacteristicMeasurementBaseType">
        <xs:sequence>
          <xs:element name="WorstPositiveDeviation"
                      type="MeasuredLinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional WorstPositiveDeviation element is the most
                positive deviation in the direction of the surface or curve
                normal. This deviation may be a negative number.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="WorstNegativeDeviation"
                      type="MeasuredLinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional WorstNegativeDeviation element is the most
                negative deviation in the direction of the surface or curve
                normal. This deviation may be a positive number.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PointDeviations"
                      type="PointDeviationsType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional PointDeviations element is a list of the
                vector deviations of measurement points from nominal.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DatumsOk"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DatumsOk element specifies whether the datum
                features passed all their associated characteristic
                evaluations. The element is set to "true" for passed all,
                is set to "false" for did not pass all, and is not present
                if the status of the datum features is unknown.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DRFTransformActualId"
                      type="QIFReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DRFTransformActualId element is the QIF id of
                the actual transform associated with the mobile DRF of this
                characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SecondCompositeSegmentProfileMeasurement"
                      type="CompositeSegmentProfileMeasurementType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional SecondCompositeSegmentProfileMeasurement
                gives information about the second segment of a
                measured composite frame profile characteristic.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ThirdCompositeSegmentProfileMeasurement"
                      type="CompositeSegmentProfileMeasurementType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ThirdCompositeSegmentProfileMeasurement gives
                information about the third segment of a measured
                composite frame profile characteristic. This element
                may be used only if the
                SecondCompositeSegmentProfileMeasurement element is used.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FourthCompositeSegmentProfileMeasurement"
                      type="CompositeSegmentProfileMeasurementType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FourthCompositeSegmentProfileMeasurement gives
                information about the fourth segment of a measured
                composite frame profile characteristic. This element
                may be used only if the
                ThirdCompositeSegmentProfileMeasurement element is used.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LineProfileCharacteristicItemType">
    <xs:annotation>
      <xs:documentation>
        The LineProfileCharacteristicItemType defines a profile of a
        line characteristic item.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LineProfileCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The LineProfileCharacteristicDefinitionType defines information
        that can be common to more than one profile of a line
        characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="Extent"
                      type="ExtentType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Extent element gives the extent of the line
                profile.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LineProfileCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The LineProfileCharacteristicNominalType defines a unique line
        profile characteristic nominal. The TargetValue for a profile of
        a line characteristic may be used to indicate a target value
        offset from the nominal curve.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicNominalBaseType">
        <xs:sequence>
          <xs:element name="Vector"
                      type="UnitVectorType">
            <xs:annotation>
              <xs:documentation>
                The Vector element is a vector perpendicular to the plane
                in which the characteristic curve lies.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ProfileCurveId"
                      type="QIFReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ProfileCurveId element is the QIF
                id of the curve feature.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LineProfileCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The LineProfileCharacteristicMeasurementType defines the results of
        a measured profile of a line characteristic evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="PointProfileCharacteristicItemType">
    <xs:annotation>
      <xs:documentation>
        The PointProfileCharacteristicItemType defines a point profile
        characteristic item.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="PointProfileCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The PointProfileCharacteristicDefinitionType defines information
        that can be common to more than one point profile characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicDefinitionBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="PointProfileCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The PointProfileCharacteristicNominalType defines a unique point
        profile characteristic nominal.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="PointProfileCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The PointProfileCharacteristicMeasurementType defines the results
        of a measured point profile characteristic evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SurfaceProfileCharacteristicItemType">
    <xs:annotation>
      <xs:documentation>
        The SurfaceProfileCharacteristicItemType defines a surface
        profile characteristic item.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SurfaceProfileCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The SurfaceProfileCharacteristicDefinitionType defines information
        that can be common to more than one profile of a surface
        characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="Extent"
                      type="ExtentType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Extent element gives the extent of the surface
                profile.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SurfaceProfileCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The SurfaceProfileCharacteristicNominalType defines a unique
        profile of a surface characteristic nominal. The TargetValue for
        a profile of a surface characteristic may be used to indicate a
        target value offset from the nominal surface.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SurfaceProfileCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The SurfaceProfileCharacteristicMeasurementType defines the results
        of a measured profile of a surface characteristic evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SurfaceProfileNonUniformCharacteristicItemType">
    <xs:annotation>
      <xs:documentation>
        The SurfaceProfileNonUniformCharacteristicItemType defines a
        non-uniform surface profile characteristic item. This characteristic
        may be used in cases where the tolerance zone itself is uniform but
        the upper disposition or (ISO specific) unequally displaced zone
        varies over the extents of the tolerance zone in which case the
        tolerance value and to-point tolerance values shall be equal.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SurfaceProfileNonUniformCharacteristicDefinitionType">
    <xs:annotation>
      <xs:documentation>
        The SurfaceProfileNonUniformCharacteristicDefinitionType defines
        information that can be common to more than one non-uniform surface
        profile characteristic. A non-uniform surface profile
        characteristic may be used for in-between and chain line
        tolerances.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicDefinitionBaseType">
        <xs:sequence>
          <xs:element name="ToPointToleranceValue"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The ToPointToleranceValue element is the tolerance at the
                ToPoint of the zone limit. The tolerance zone varies
                proportionally with the distance along the curve (line,
                arc, or other) from the FromPoint to the ToPoint. The
                ToleranceValue applies at the FromPoint and the
                ToPointToleranceValue applies at the ToPoint.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ToPointToleranceDualValue"
                      type="LinearDualValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ToPointToleranceDualValue element is the
                dual tolerance at the ToPoint of the zone limit.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ToPointOuterOrUnequal"
                      type="OuterOrUnequalType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ToPointOuterOrUnequal element gives a choice
                between the ASME Y14.5 and ISO 1101 implementations of
                unequal, unilateral or offset profile tolerance zones
                to define the tolerance zone at the ToPoint.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SurfaceProfileNonUniformCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The SurfaceProfileNonUniformCharacteristicNominalType defines a
        unique non-uniform surface profile characteristic nominal.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicNominalBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SurfaceProfileNonUniformCharacteristicMeasurementType">
    <xs:annotation>
      <xs:documentation>
        The SurfaceProfileNonUniformCharacteristicMeasurementType defines
        the results of a measured non-uniform surface profile
        characteristic evaluation.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ProfileCharacteristicMeasurementBaseType"/>
    </xs:complexContent>
  </xs:complexType>

<!-- END PROFILE CHARACTERISTIC TYPES -->

