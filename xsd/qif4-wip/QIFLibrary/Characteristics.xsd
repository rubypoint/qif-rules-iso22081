        characteristic.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="OrientationCharacteristicDefinitionBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="PerpendicularityCharacteristicNominalType">
    <xs:annotation>
      <xs:documentation>
        The PerpendicularityCharacteristicNominalType defines a unique
