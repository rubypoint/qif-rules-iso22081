        defines an edge treatment item for a treatment
        that reduces an internal edge.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="EdgeTreatmentCharacteristicItemBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="InternalEdgeReductionCharacteristicMeasurementType">
