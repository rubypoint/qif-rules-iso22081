  <xs:element name="MeasurementDevice"
              type="MeasurementDeviceBaseType"
              abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract global MeasurementDevice element is the head of a
        substitution group. In an instance file, an element that is a
        member of the group shall be substituted for the
        MeasurementDevice element anywhere a schema file indicates the
        MeasurementDevice element may be used and it is necessary or
        desired to populate the element.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="UserDefinedMeasurementDevice"
              type="UserDefinedMeasurementDeviceType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global UserDefinedMeasurementDevice element gives
        information about a measurement device that is not otherwise
        defined.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

<!-- BEGIN MANUAL MEASUREMENT DEVICE  SUBSTITUTES -->

  <xs:element name="BoreGage"
