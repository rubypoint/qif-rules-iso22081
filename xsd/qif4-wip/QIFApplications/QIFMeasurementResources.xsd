  <xs:element name="Micrometer"
              type="MicrometerType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global Micrometer element gives information about a micrometer.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="FeelerGage"
              type="FeelerGageType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global FeelerGage element gives information about an
        index of feeler gage leaves. It is a device used to determine the
        linear width of small gaps.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="GageBlock"
              type="GageBlockType"
              substitutionGroup="MeasurementDevice">
