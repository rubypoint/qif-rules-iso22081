                measuring distance.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxMeasuringDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxMeasuringDistance element is the maximum
                measuring distance.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HousingMaterial"
                      type="MaterialType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HousingMaterial element is the type of
                housing material for a laser triangulation sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PermissibleAmbientLight"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional PermissibleAmbientLight element is the
                permissible ambient light.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ShockTolerance"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ShockTolerance element is the level of
                shock tolerance for a laser triangulation sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="VibrationTolerance"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional VibrationTolerance element is the level
                of vibration tolerance for a laser triangulation sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="OutputPower"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional OutputPower element is the output power of the
                laser beam.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Laser"
                      type="LaserType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Laser element is the laser used in the laser
                triangulation sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="StructuredLightSensorType">
    <xs:annotation>
      <xs:documentation>
        The StructuredLightSensorType defines a sensor based on a
        structured light principle.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="SensorBaseType">
        <xs:sequence>
          <xs:element name="OutputFileFormat"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional OutputFileFormat element is the format of the
                output file.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MeasurementFieldSize"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MeasurementFieldSize element is the field size
                for a structured light sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NumberOfCameraPixels"
                      type="xs:int"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NumberOfCameraPixels element is the number of
                camera pixels.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LightSource"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LightSource element is the type of light
                source used in a structured light sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MeasurementRate"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MeasurementRate element is the number of
                measurements carried out per second.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element ref="WorkingVolume"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional WorkingVolume element is the working
                volume that the structured light sensor scans.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StandOffDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StandOffDistance element is the Standoff
                distance from a structured light sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxPermissibleProbingError"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxPermissibleProbingError element is the
                maximum permissible probing error using structured light
                sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Laser"
                      type="LaserType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Laser element is the laser used in a
                structured light sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="UltrasonicSensorType">
    <xs:annotation>
      <xs:documentation>
        The UltrasonicSensorType defines an ultrasonic sensor.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="SensorBaseType">
        <xs:sequence>
          <xs:element name="MinMeasuringDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MinMeasuringDistance element is the minimum
                measuring distance.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxMeasuringDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxMeasuringDistance element is the maximum
                measuring distance.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SamplingFrequency"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional SamplingFrequency element is the sampling
                rate (frequency) of an ultrasonic sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AppliedFrequency"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional AppliedFrequency element is the frequency
                used for the measurement.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxResponseTime"
                      type="TimeValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxResponseTime element is the maximum
                response time for measurement with an ultrasonic sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ShockTolerance"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ShockTolerance element is the level of
                shock tolerance for an ultrasonic sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="VibrationTolerance"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional VibrationTolerance element is the level
                of vibration tolerance for an ultrasonic sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MinPowerSupplyVoltage"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MinPowerSupplyVoltage element is the minimum
                power supply voltage of an ultrasonic sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxPowerSupplyVoltage"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxPowerSupplyVoltage element is the maximum
                power supply voltage of an ultrasonic sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:simpleType name="TipEndGeometryEnumType">
    <xs:annotation>
      <xs:documentation>
        The TipEndGeometryEnumType enumerates values that describe the
        shape of the end of a probe tip. The tip end is the portion of a
        probe tip that that contacts the workpiece being probed.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:NMTOKEN">
      <xs:enumeration value="SPHERE"/>
      <xs:enumeration value="CYLINDER"/>
      <xs:enumeration value="CYLINDER_WITH_SPHERE"/>
      <xs:enumeration value="HEMISPHERE"/>
      <xs:enumeration value="SPHERICAL_DISC"/>
      <xs:enumeration value="POINT"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="TipEndGeometryType">
    <xs:annotation>
      <xs:documentation>
        The TipEndGeometryType defines a type of probe tip end shape. The
        tip end is the portion of a probe tip that contacts the workpiece
        being probed.
      </xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="TipEndGeometryEnum"
                  type="TipEndGeometryEnumType">
        <xs:annotation>
          <xs:documentation>
            The TipEndGeometryEnum element describes an often-used tip
            end shape.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OtherTipEndGeometry"
                  type="xs:string">
        <xs:annotation>
          <xs:documentation>
            The OtherTipEndGeometry element describes a tip end shape in
            natural language.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="TactileProbeSensorBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract TactileProbeSensorBaseType is the base type that
        defines a tactile probe. A TactileProbeSensorBaseType is often
        called a stylus.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="DetachableSensorBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SimpleTactileProbeSensorType">
    <xs:annotation>
      <xs:documentation>
        The SimpleTactileProbeSensorType defines a detachable tactile probe
        with a single tip that extends straight from its mounting. The tip
        might or might not be detachable from the body of the probe.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="TactileProbeSensorBaseType">
        <xs:sequence>
          <xs:element name="Qualifications"
                      type="QualificationsType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Qualifications element is a list of
                qualifications of the simple tactile probe.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Length"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Length element is the length of the tactile
                probe from the point where the probe attaches to the tool
                to the end of the tip.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TipEndGeometry"
                      type="TipEndGeometryType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TipEndGeometry element is the shape of the end
                of the tip, i.e. the thing at the end of the tip that
                contacts an object being probed.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TipEndDiameter"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TipEndDiameter element is the nominal diameter
                of the end of the probe tip.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TipEndMaterial"
                      type="MaterialType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TipEndMaterial element is the material that
                the tip end is made of.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StemMaterial"
                      type="MaterialType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StemMaterial element is the material that the
                stem of the tip is made of.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StemDiameter"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StemDiameter element is the diameter of the
                stem of the probe.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ComplexTactileProbeSensorType">
    <xs:annotation>
      <xs:documentation>
        The ComplexTactileProbeSensorType defines a tactile probe with
        one or more tips.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="TactileProbeSensorBaseType">
        <xs:sequence>
          <xs:element name="LocatedTips"
                      type="LocatedTipsType">
            <xs:annotation>
              <xs:documentation>
                The LocatedTips element is a list of located tips. Each
                located tip is the tip of the probe plus the location of
                the end of its tip with respect to the coordinate system of
                the probe. Each tip might or might not be detachable from
                the probe.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LocatedTipsType">
    <xs:annotation>
      <xs:documentation>
        The LocatedTipsType defines a list of located tips.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="LocatedTip"
                  type="LocatedTipType"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each LocatedTip element gives information about a located tip.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of located tips in the
          list.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="ProbeTipType">
    <xs:annotation>
      <xs:documentation>
        The ProbeTipType defines a tip of a tactile probe. A probe tip has
        a stem and an end. A ProbeTipType might or might not be detachable.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="MeasurementResourceBaseType">
        <xs:sequence>
          <xs:element name="TipEndGeometry"
                      type="TipEndGeometryType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TipEndGeometry element is the shape of the end
                of the tip, i.e. the thing at the end of the tip that
                contacts an object being probed.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TipEndDiameter"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TipEndDiameter element is the nominal diameter
                of the end of the probe tip.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TipEndCurrentDiameter"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TipEndCurrentDiameter element is the current
                diameter of the end of the probe tip. This may be found by
                measurement or estimated (e.g., by using wear rules).
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TipEndDiameterMin"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TipEndDiameterMin element is the minimum
                diameter of the end of the probe tip at which the tip is
                usable.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TipEndMaterial"
                      type="MaterialType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TipEndMaterial element is the material
                that the tip end is made of.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StemMaterial"
                      type="MaterialType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StemMaterial element is the material that
                the stem of the tip is made of.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StemDiameter"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StemDiameter element is the diameter of the
                stem of the probe tip.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LocatedTipType">
    <xs:annotation>
      <xs:documentation>
        The LocatedTipType defines a tip of a tactile probe and the location
        of the end of tip.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ProbeTip"
                  type="ProbeTipType">
        <xs:annotation>
          <xs:documentation>
            The ProbeTip element is a probe tip.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TipEndLocation"
                  type="PointType">
        <xs:annotation>
          <xs:documentation>
            The TipEndLocation element is the location of the point at the
            end of the tip.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ChargeCoupledDeviceCameraSensorType">
    <xs:annotation>
      <xs:documentation>
        The ChargeCoupledDeviceCameraSensorType defines a Charge Coupled
        Device (CCD) camera.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="SensorBaseType">
        <xs:sequence>
          <xs:element name="NumberOfPixels"
                      type="xs:int"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NumberOfPixels element is the number of
                pixels in a charge coupled device (CCD) camera.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxReadoutFrequency"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxReadoutFrequency element is the
                maximum reading frequency.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HorizontalFieldOfView"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HorizontalFieldOfView element is the size of
                the charge coupled device (CCD) camera Horizontal field of
                view.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="VerticalFieldOfView"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional VerticalFieldOfView element is the size of the
                charge coupled device (CCD) camera Vertical field of view.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxReadNoise"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxReadNoise element is the maximum noise in a
                charge coupled device (CCD) camera during reading.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxFrameRate"
                      type="PositiveDoubleType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxFrameRate element is the maximum number of
                frames per second that the charge coupled device (CCD)
                camera could capture.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PixelSize"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional PixelSize element is the size of charge
                coupled device (CCD) camera pixel.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SustainedDataRate"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional SustainedDataRate element is the data transfer
                rate (sending and receiving) for a charge coupled device
                (CCD) camera.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DarkCurrent"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DarkCurrent element is the current that
                charge coupled device (CCD) camera generates in the dark
                level (no illumination).
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxPixelClockSpeed"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxPixelClockSpeed element is the maximum
                clock speed of a charge coupled device (CCD) camera pixel.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Linearity"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Linearity element is the error in the
                linearity of a charged couple device (CCD) camera.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxOutputVoltage"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxOutputVoltage element is the maximum
                output voltage of a charge coupled device (CCD) camera.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

<!-- END SENSOR TYPES -->

<!-- BEGIN MEASUREMENT DEVICE TYPES -->

<!-- BEGIN CMM TYPES -->

  <xs:complexType name="CMMBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract CMMBaseType defines a CMM measurement device.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="UniversalDeviceBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="OtherCMMType">
    <xs:annotation>
      <xs:documentation>
        The OtherCMMType defines a CMM measurement device that is not
        a CartesianCMM, LightPenCMM, ParallelLinkCMM, or AACMM.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="CMMBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="CartesianCMMType">
    <xs:annotation>
      <xs:documentation>
        The CartesianCMMType defines a Cartesian CMM with zero or one
        rotary table and zero to many tools. A Cartesian CMM is assumed to
        have a fixed native 3D Cartesian coordinate system.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="CMMBaseType">
        <xs:sequence>
          <xs:element name="HomeLocation"
                      type="PointType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HomeLocation element gives the home location of
                the tool mount point of the Cartesian CMM in the coordinate
                system of the Cartesian CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CMMGeometry"
                      type="CartesianCMMGeometryType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CMMGeometry element gives the type of the
                construction of the Cartesian CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element ref="CMMAxisDirections"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CMMAxisDirections element gives the
                orientation of the axes of the coordinate system of
                the Cartesian CMM with respect to the machine.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element ref="Scales"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Scales element describes the scales
                used on the Cartesian CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxWorkpieceHeight"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxWorkpieceHeight element gives the
                maximum height (vertical extent) of an object to be
                measured when the object is placed on the bed of the
                Cartesian CMM in the desired orientation.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxWorkpieceMass"
                      type="MassValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxWorkpieceMass element gives the
                maximum mass of an object to be measured.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="JoystickSpeeds"
                      type="CartesianCMMSpeedsType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional JoystickSpeeds element describes the
                maximum speed in joystick mode of each axis for
                traversing and probing.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element ref="CMMSpeeds"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CMMSpeeds element describes the maximum
                speed in CNC mode of each axis for traversing and
                probing.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RotaryTable"
                      type="RotaryTableType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional RotaryTable element describes a rotary
                table attached to the Cartesian CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Performances"
                      type="CartesianCMMPerformancesType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Performances element is a list of CMM
                performances, each of which gives the performance of the
                Cartesian CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ToolIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ToolIds element is a list of the QIF ids of
                Cartesian CMM measurement tools associated with the
                Cartesian CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SensorIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional SensorIds element is a list of the QIF ids of
                detachable sensors associated with the Cartesian CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="MultipleCarriageCartesianCMMType">
    <xs:annotation>
      <xs:documentation>
        The MultipleCarriageCartesianCMMType defines a Cartesian CMM with
        two or more carriages.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="CartesianCMMType">
        <xs:sequence>
          <xs:element name="Carriages"
                      type="CarriagesType">
            <xs:annotation>
              <xs:documentation>
                The Carriages element is a list of carriages.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LightPenCMMType">
    <xs:annotation>
      <xs:documentation>
        The LightPenCMMType defines a light pen CMM.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="CMMBaseType">
        <xs:sequence>
          <xs:element name="LightPenCMMChargeCoupledDeviceCameraSensor"
                      type="ChargeCoupledDeviceCameraSensorType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LightPenCMMChargeCoupledDeviceCameraSensor
                element is a Charge Coupled Device (CCD) camera used
                in measurement with a light pen CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LightSource"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LightSource element is the type of light
                source used in a light pen CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NominalVolumetricAccuracy"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NominalVolumetricAccuracy element is the
                nominal volumetric accuracy of a light pen CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ActualVolumetricAccuracy"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ActualVolumetricAccuracy element is the
                actual volumetric accuracy of a light pen CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NominalSinglePointAccuracy"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NominalSinglePointAccuracy element is the
                nominal single point accuracy for a light pen CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ActualSinglePointAccuracy"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ActualSinglePointAccuracy element is the
                actual single point accuracy for a light pen CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ScanningSpeed"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ScanningSpeed element is the scanning
                speed for a light pen CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LaserClass"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LaserClass element is the laser class for
                a light pen CMM laser.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="ParallelLinkCMMType">
    <xs:annotation>
      <xs:documentation>
        The ParallelLinkCMMType defines a parallel link coordinate measuring
        machine.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="CMMBaseType">
        <xs:sequence>
          <xs:element ref="CMMSpeeds"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CMMSpeeds element is the linear and
                rotational speeds of a parallel link CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AxesTravelDistance"
                      type="XYZLinearSpecificationType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional AxesTravelDistance element is the travel
                distance for X, Y, and Z axes of a parallel link CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AxesRotationAngle"
                      type="AngularValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional AxesRotationAngle element is the rotation
                angle around X, Y, and Z axes of a parallel link CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AxisBacklash"
                      type="XYZLinearSpecificationType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional AxisBacklash element is the backlash in
                the X, Y, and Z axes of a parallel link CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AxisRepeatability"
                      type="XYZLinearSpecificationType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional AxisRepeatability element is the
                repeatability for X, Y, and Z axes of a parallel link CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxLoad"
                      type="MassValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxLoad element is the maximum load that
                could be mounted on a parallel link CMM stage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StageMaterial"
                      type="MaterialType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StageMaterial element is the type of the
                material used for stage manufacturing of a parallel link
                CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxHoldingForce"
                      type="ForceValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxHoldingForce element is the maximum
                force to hold the base plate of a parallel link CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TypeOfMotor"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TypeOfMotor element is the type of motor
                used in a parallel link CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LinksStiffness"
                      type="StiffnessType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LinksStiffness element is the stiffness
                for a parallel link CMM in X, Y, and Z directions.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ToolIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ToolIds element is a list of the QIF ids of
                parallel link CMM measurement tools associated with the
                parallel link CMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

<!-- why does AACMMType not have ToolIds? -->

  <xs:complexType name="AACMMType">
    <xs:annotation>
      <xs:documentation>
        The AACMMType defines an articulated arm CMM.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="CMMBaseType">
        <xs:sequence>
          <xs:element name="HomeLocation"
                      type="PointType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HomeLocation element gives the coordinates of
                home location of the AACMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NumberOfJoints"
                      type="xs:int"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NumberOfJoints element is the number
                of joints in the AACMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MinMeasuringDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MinMeasuringDistance element is the minimum
                measurement distance of the AACMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxMeasuringDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxMeasuringDistance element is the maximum
                measurement distance of the AACMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ProbeTipDiameter"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ProbeTipDiameter element is the diameter
                of probe tip for the AACMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Performances"
                      type="AACMMPerformancesType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Performances element is a list of CMM
                performances, each of which defines the performance of the
                AACMM.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

<!-- END CMM TYPES -->

<!-- BEGIN MANUAL DEVICES TYPES -->

  <xs:complexType name="ManualMeasurementDeviceBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract ManualMeasurementDeviceBaseType defines a
        measurement device that is intended to be operated hands-on by
        a human user - not with a joystick or other electronic control
        interface device.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="MeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="ElectronicOutput"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ElectronicOutput element indicates whether
                the measurement device stores or transmits its measurement
                indication electronically, so that the user does not have
                to record data manually.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DigitalDisplay"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DigitalDisplay element indicates whether
                the measurement device displays its measurement indication
                on a digital screen.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LinearManualMeasurementDeviceBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract LinearManualMeasurementDeviceBaseType defines a
        manual measurement device that measures a dimension, distance, or
        displacement along a linear axis.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="LinearResolution"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LinearResolution element is the linear
                resolution of the linear manual measurement device.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MinMeasuringDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MinMeasuringDistance element is the minimum
                measuring distance for the linear manual measurement device.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxMeasuringDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxMeasuringDistance element is the maximum
                measuring distance for the linear manual measurement device.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Performances"
                      type="NumericalLengthPerformancesType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Performances element is a list of numerical
                length performances, each of which defines the performance
                of the linear manual measurement device.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="BoreGageType">
    <xs:annotation>
      <xs:documentation>
        The BoreGageType defines a bore gage, a device used to measure
        the diameter of an internal cylinder.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="LinearManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="MaxMeasuringDepth"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxMeasuringDepth element gives the maximum
                depth from the surface of a part that the bore gage is
                able to be used to measure.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NumberOfContactPoints"
                      type="NaturalType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NumberOfContactPoints element gives the
                number of places that the bore gage contacts the inside
                of a bore being measured.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HasDial"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HasDial element should be set to true if
                the bore gage has a dial. Otherwise, it should be set to
                false. Not using the element is equivalent to false.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="CaliperType">
    <xs:annotation>
      <xs:documentation>
        The CaliperType defines a caliper measurement device.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="LinearManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="CanMeasureInnerD"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CanMeasureInnerD element should be set to
                true if the caliper is able measure an inner diameter.
                Otherwise, it should be set to false.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CanMeasureOuterD"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CanMeasureOuterD element should be set to
                true if the caliper is able to measure an outer
                diameter. Otherwise, it should be set to false.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CanMeasureDepth"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CanMeasureDepth element should be set to
                true if the caliper is able to measure the depth of a
                hole. Otherwise, it should be set to false.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HasDial"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HasDial element should be set to true if
                the caliper has a dial. Otherwise, it should be set to
                false. Not using the element is equivalent to false.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="MicrometerType">
    <xs:annotation>
      <xs:documentation>
        The MicrometerType defines a micrometer.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="LinearManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="MeasuringForce"
                      type="ForceValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MeasuringForce element is the force
                applied by a micrometer during measurement.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="InternalExternal"
                      type="InternalExternalEnumType"
                      default="INTERNAL"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional InternalExternal element indicates whether
                the micrometer is internal (placed inside the feature for
                measurement) or external (placed outside).
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="HeightGageType">
    <xs:annotation>
      <xs:documentation>
        The HeightGageType defines information about a height gage,
        a device used to determine the linear distance between a surface
        plate and the top of an object.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="LinearManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="HasDial"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HasDial element indicates whether the height
                gage has a dial-type readout.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="BaseWidth"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional BaseWidth element defines the width of the
                height gage base as defined by ISO 13225:2012.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="BaseDepth"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional BaseDepth element defines the depth of
                the height gage base as defined by ISO 13225:2012.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ProbeExtensionOffset"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ProbeExtensionOffset element defines the linear
                distance that a probe extension protrudes from the height
                gage beam as defined by ISO 13225:2012.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MinStylusLength"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MinStylusLength element defines the
                minimum stylus length that is able to be accommodated
                by the height gage as defined by ISO 13225:2012.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxStylusLength"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxStylusLength element defines the
                maximum stylus length that is able be accommodated by
                the height gage as defined by ISO 13225:2012.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HasAirBearing"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HasAirBearing element indicates whether
                the height gage base floats on an air bearing.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AirBearingPressureRequirement"
                      type="PressureValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional AirBearingPressureRequirement element
                defines the supply air pressure required by the height
                gage air bearing.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AirBearingFlowRateRequirement"
                      type="xs:double"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional AirBearingFlowRateRequirement element
                defines the volumetric flow rate of air that is
                required by the height gage air bearing.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FlowRateUnit"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FlowRateUnit element is the name of unit
                in which the AirBearingFlowRateRequirement is given.
                This shall be defined in the UserDefinedUnits and be
                some constant times meters cubed times seconds to the
                minus one. If this element is not used, the unit is
                cubic meters per second.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HasStylusFixingDevice"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HasStylusFixingDevice element indicates
                whether the height gage has a stylus fixing device as
                defined by ISO 13225:2012.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HasFineAdjustment"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HasFineAdjustment element indicates
                whether the height gage has a fine adjustment
                mechanism as defined by ISO 13225:2012.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HasWaterDustProtection"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HasWaterDustProtection element indicates
                whether the height gage is designed to resist the
                ingress of water, dirt, or other foreign material.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="WaterDustProtectionIPRating"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional WaterDustProtectionIPRating element
                defines the ingress protection (IP) rating of the
                height gage as defined by IEC 60529.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="FeelerGageType">
    <xs:annotation>
      <xs:documentation>
        The FeelerGageType defines a feeler gage measurement device
        with one or more leaves of the same length and shape but
        different thicknesses.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="LinearManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="LeafThicknessTolerance"
                      type="LinearToleranceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LeafThicknessTolerance element is the
                tolerance applied to the linear thickness of the
                feeler gage leaves.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LeafLength"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LeafLength element is the linear length
                of the feeler gage leaves.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LeafWidth"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LeafWidth element is the linear width of
                the feeler gage leaves.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LeafShape"
                      type="FeelerGageLeafShapeType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LeafShape element describes the shape of
                the feeler gage leaves, apart from whether the end is
                bent.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HasBentEnd"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional HasBentEnd element defines whether the
                ends of the feeler gage leaves are bent, typically to
                a nominal 45-degree angle.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LeafSet"
                      type="FeelerGageLeafSetType">
            <xs:annotation>
              <xs:documentation>
                The LeafSet element describes the leaves of the feeler gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="FeelerGageLeafType">
    <xs:annotation>
      <xs:documentation>
        The FeelerGageLeafType describes the thickness of a
        feeler gage leaf identified by its index number. The
        thickness tolerance, shape, length, and width of a
        leaf in a FeelerGage is specified in the FeelerGageType.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Thickness"
                  type="LinearValueType">
        <xs:annotation>
          <xs:documentation>
            The Thickness element is the thickness of the leaf.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Index"
                  type="NaturalType">
        <xs:annotation>
          <xs:documentation>
            The Index element is the index of the leaf. In a feeler
            gage device, indexes shall be assigned 1, 2, 3, etc.
            in the order leaves occur in the gage, with the thinner of
            the two end leaves having index 1.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="FeelerGageLeafSetType">
    <xs:annotation>
      <xs:documentation>
        The FeelerGageLeafSetType describes a set of
        feeler gage leaves identified by index number.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Leaf"
                  type="FeelerGageLeafType"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each Leaf element gives the thickness of a feeler gage
            element with a given index.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute gives the number of leaves in the set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:simpleType name="StraightOrTaperedEnumType">
    <xs:annotation>
      <xs:documentation>
        The StraightOrTaperedEnumType enumerates values that describe
        whether feeler gage leaves are straight or tapered.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:NMTOKEN">
      <xs:enumeration value="STRAIGHT"/>
      <xs:enumeration value="TAPERED"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="FeelerGageLeafShapeType">
    <xs:annotation>
      <xs:documentation>
        The FeelerGageLeafShapeType defines the shape of feeler
        gage leaves.
      </xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="FeelerGageLeafShapeEnum"
                  type="StraightOrTaperedEnumType">
        <xs:annotation>
          <xs:documentation>
            The FeelerGageLeafShapeEnum element describes a common
            feeler gage leaf shape.    
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OtherFeelerGageLeafShape"
                  type="xs:string">
        <xs:annotation>
          <xs:documentation>
            The OtherFeelerGageLeafShape element describes the shape
            of feeler gage leaves in natural language.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

<!--
The type of the InstructionsForUse element will be changed to
WorkInstructionsType. That is currently defined in QIFPlans.xsd
but will need to be moved to IntermediatesPMI.xsd or PrimitivesPMI.xsd
so that it can be used for both resources and plans.
-->

  <xs:complexType name="FunctionalFitGageType">
    <xs:annotation>
      <xs:documentation>
        The FunctionalFitGageType defines a hard gage for evaluating a
        specific characteristic or characteristics on instances of a
        single part design or a family of part designs.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="Target"
                      type="FunctionalFitGageTargetType">
            <xs:annotation>
              <xs:documentation>
                The Target element describes the part or parts for
                whose inspection the gage is intended to be used.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="InstructionsForUse"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional InstructionsForUse element describes
                instructions for using the gage in the intended
                application.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Tolerances"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Tolerances element describes manufacturing
                tolerances of the gage relevant to the intended application.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="GoOrNoGo"
                      type="GoOrNoGoEnumType">
            <xs:annotation>
              <xs:documentation>
                The GoOrNoGo element indicates whether the gage is a go
                gage or a no go gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="FunctionalFitGageTargetType">
    <xs:annotation>
      <xs:documentation>
        The FunctionalFitGageTargetType provides a choice of methods
        for identifying the part or parts on which the gage may be used.
      </xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="Description"
                  type="xs:string">
        <xs:annotation>
          <xs:documentation>
            The Description element describes a single part or family of
            parts in natural language.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="References"
                  type="ArrayReferenceType">
        <xs:annotation>
          <xs:documentation>
            The References element is a list of the QIF ids of parts
            or assemblies for which a particular gage may be
            used. Each entry in the list may be the id of a part or
            assembly in the same or an external QIF file, or it may be
            the QIF id of an external non-QIF entity.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="PinGageBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract PinGageBaseType defines a pin gage measurement device.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="LinearManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="PinGageClass"
                      type="xs:string">
            <xs:annotation>
              <xs:documentation>
                The PinGageClass element describes manufacturing tolerance
                of the pin gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="UnthreadedPinGageBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract UnthreadedPinGageBaseType defines an unthreaded
        pin gage.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="PinGageBaseType">
        <xs:sequence>
          <xs:element name="PinDiameterTolerance"
                      type="LinearToleranceType">
            <xs:annotation>
              <xs:documentation>
                The PinDiameterTolerance element describes the
                diameter tolerance of the pin gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SingleEndPinGageType">
    <xs:annotation>
      <xs:documentation>
        The SingleEndPinGageType defines an unthreaded
        pin gage with a specified diameter on one end.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="UnthreadedPinGageBaseType">
        <xs:sequence>
          <xs:element name="GoOrNoGo"
                      type="GoOrNoGoEnumType">
            <xs:annotation>
              <xs:documentation>
                The GoOrNoGo element indicates whether the gage is a go
                gage or a no go gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PinDiameter"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The PinDiameter element is the diameter of the pin gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="DoubleEndPinGageType">
    <xs:annotation>
      <xs:documentation>
        The DoubleEndPinGageType defines an unthreaded pin gage with a
        specified diameter on both ends. One of the ends has a go diameter.
        The other end has a no go diameter.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="UnthreadedPinGageBaseType">
        <xs:sequence>
          <xs:element name="GoDiameter"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The GoDiameter element is the diameter of the go end
                of the pin gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NoGoDiameter"
                      type="LinearValueType">
            <xs:annotation>
              <xs:documentation>
                The NoGoDiameter element is the diameter of the no go end
                of the pin gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:simpleType name="GoOrNoGoEnumType">
    <xs:annotation>
      <xs:documentation>
        The GoOrNoGoEnumType enumerates values that describe
        whether a single ended pin gage is a go gage or a no go gage.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:NMTOKEN">
      <xs:enumeration value="GO"/>
      <xs:enumeration value="NOGO"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="ThreadedPinGageBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract ThreadedPinGageBaseType defines a threaded pin gage.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="PinGageBaseType">
        <xs:sequence>
          <xs:element name="ThreadSpecificationId"
                      type="QIFReferenceType">
            <xs:annotation>
              <xs:documentation>
                The ThreadSpecificationId element is the QIF id of a
                thread specification.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="SingleEndThreadedPinGageType">
    <xs:annotation>
      <xs:documentation>
        The SingleEndThreadedPinGageType defines a threaded pin gage
        with a single usable end.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ThreadedPinGageBaseType">
        <xs:sequence>
          <xs:element name="GoOrNoGo"
                      type="GoOrNoGoEnumType">
            <xs:annotation>
              <xs:documentation>
                The GoOrNoGo element indicates whether the gage is a
                go gage or a no go gage.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="DoubleEndThreadedPinGageType">
    <xs:annotation>
      <xs:documentation>
        The DoubleEndThreadedPinGageType defines a threaded pin gage
        with a go end and a no go end.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ThreadedPinGageBaseType"/>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="GageBlockType">
    <xs:annotation>
      <xs:documentation>
        The GageBlockType defines a gage block, a reference artifact with
        calibrated length or size.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="LinearManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="Length"
                      type="MeasuredLinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Length element is the length of
                the gage block as defined by ASME B89.1.9-2023 and
                ISO 3650:1998.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Grade"
                      type="GageBlockGradeType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Grade element describes the grade of
                the gage block.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Material"
                      type="MaterialType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Material element describes the material
                from which the gage block is made.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="GageBlockGradeType">
    <xs:annotation>
      <xs:documentation>
        The GageBlockGradeType defines the grade of a gage block.
      </xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="GageBlockGradeEnum"
                  type="GageBlockGradeEnumType">
        <xs:annotation>
          <xs:documentation>
            The GageBlockGradeEnum element describes a gage block
            grade defined by ASME B89.1.9-2023 or ISO 3650:1998.    
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OtherGageBlockGrade"
                  type="xs:string">
        <xs:annotation>
          <xs:documentation>
            The OtherGageBlockGrade element describes the grade of
            a gage block in natural language as defined by other or
            outdated documentary standards.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:simpleType name="GageBlockGradeEnumType">
    <xs:annotation>
      <xs:documentation>
        The GageBlockGradeEnumType enumerates values that describe
        a gage block grade defined by ASME B89.1.9-2023 or ISO 3650:1998. 
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:NMTOKEN">
      <xs:enumeration value="ASME_B89.1.9-2023_K"/>
      <xs:enumeration value="ASME_B89.1.9-2023_00"/>
      <xs:enumeration value="ASME_B89.1.9-2023_0"/>
      <xs:enumeration value="ASME_B89.1.9-2023_AS_1"/>
      <xs:enumeration value="ASME_B89.1.9-2023_AS_2"/>
      <xs:enumeration value="ISO_3650:1998_K"/>
      <xs:enumeration value="ISO_3650:1998_0"/>
      <xs:enumeration value="ISO_3650:1998_1"/>
      <xs:enumeration value="ISO_3650:1998_2"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="SineBarType">
    <xs:annotation>
      <xs:documentation>
        The SineBarType defines a sine bar.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="LinearManualMeasurementDeviceBaseType">
        <xs:sequence>
          <xs:element name="NominalBallCenterToBallCenterLength"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NominalBallCenterToBallCenterLength element
                defines the nominal distance between the two sine bar balls.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CylinderCenterToCylinderCenterAccuracy"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CylinderCenterToCylinderCenterAccuracy element
                defines the accuracy between the two sine bar cylinder
                centers.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Parallelism"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Parallelism element is the parallelism
                between the upper and lower planes of a sine bar.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="OverallLength"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional OverallLength element is the overall
                length of a sine bar.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Material"
                      type="MaterialType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Material element is the material that a
                sine bar is made.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Magnetic"
                      type="xs:boolean"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Magnetic element is the magnetic
                capability of a sine bar.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Width"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Width element is the width of a sine bar.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

<!-- END MANUAL DEVICES TYPES -->

<!-- BEGIN OTHER DEVICES TYPES -->

  <xs:complexType name="TheodoliteType">
    <xs:annotation>
      <xs:documentation>
        The TheodoliteType defines a theodolite measuring device.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="UniversalDeviceBaseType">
        <xs:sequence>
          <xs:element name="LongitudinalTrackingSpeed"
                      type="SpeedValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LongitudinalTrackingSpeed element is the
                maximum speed in longitudinal tracking with a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LateralTrackingSpeed"
                      type="SpeedValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LateralTrackingSpeed element is the
                maximum speed in lateral tracking with a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Magnification"
                      type="xs:double"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Magnification element is the maximum
                magnification in measuring with a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FieldOfViewDiameter"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FieldOfViewDiameter element is the field
                of view diameter of a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ApertureSize"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ApertureSize element is the aperture size
                of a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxFocusDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxFocusDistance element is the (maximum)
                focal distance of a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AngularAccuracy"
                      type="AngularValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional AngularAccuracy element is the accuracy in
                measuring an angle with a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxTiltCompensation"
                      type="AngularValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxTiltCompensation element is the
                maximum tilt compensated with the tilt sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ChargeCoupledDeviceCameraSensor"
                      type="ChargeCoupledDeviceCameraSensorType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ChargeCoupledDeviceCameraSensor element
                defines the charge coupled device (CCD) camera associated
                with a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MinFocusDistance"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MinFocusDistance element is the minimum
                focal distance of a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="EffectiveDiameterOfObjective"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional EffectiveDiameterOfObjective element is
                the effective diameter of the theodolite objective.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StadiaBaseConstant"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StadiaBaseConstant element is the
                additive stadia constant of a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StadiaRateConstant"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional StadiaRateConstant element is the
                multiplier constant of stadia.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MinPowerSupplyVoltage"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MinPowerSupplyVoltage element is the minimum
                power supply voltage of a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxPowerSupplyVoltage"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxPowerSupplyVoltage element is the
                maximum power supply voltage of a theodolite.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Laser"
                      type="LaserType"
                      minOccurs="0">
            <xs:annotation>
