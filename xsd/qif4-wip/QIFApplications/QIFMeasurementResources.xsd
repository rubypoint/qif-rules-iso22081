    </xs:annotation>
  </xs:element>

  <xs:element name="DoubleEndPinGage"
              type="DoubleEndPinGageType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global DoubleEndPinGage element gives information about
        an unthreaded pin gage device with a go end and a no go end.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="SingleEndThreadedPinGage"
              type="SingleEndThreadedPinGageType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global SingleEndThreadedPinGage element gives information about
        a threaded single diameter pin gage device.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="DoubleEndThreadedPinGage"
              type="DoubleEndThreadedPinGageType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global DoubleEndThreadedPinGage element gives information about
        a threaded pin gage device with a go end and a no go end.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="SineBar"
              type="SineBarType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global SineBar element gives information about a sine bar.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="FunctionalFitGage"
              type="FunctionalFitGageType"
