              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxOperatingCurrent"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxOperatingCurrent element is the
                maximum operating current for the computed tomography
                machine.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxFramePerSecond"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional MaxFramePerSecond element is the maximum
                number of images that the computed tomography machine
