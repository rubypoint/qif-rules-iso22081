<!-- START SUBSTITUTION GROUP FOR CMMs -->

  <xs:element name="AACMM"
              type="AACMMType"
              substitutionGroup="CMM">
    <xs:annotation>
      <xs:documentation>
        The global AACMM element gives information about an articulated arm
        coordinate measuring machine (AACMM).
      </xs:documentation>
    </xs:annotation>
  </xs:element>

