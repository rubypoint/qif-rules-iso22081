                points, in terms of points per unit of time.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaxMeasurementRange"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
