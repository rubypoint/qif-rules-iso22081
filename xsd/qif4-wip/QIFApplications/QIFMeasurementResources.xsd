<!-- BEGIN DEFINITION OF WORKINGCLOSEDSHELLSET ELEMENT -->

  <xs:element name="WorkingClosedShellSet"
              type="ClosedShellSetType">
    <xs:annotation>
      <xs:documentation>
        The global WorkingClosedShellSet element gives information
        about a closed shell set.

        Each key in this element requires each item in a collection of
        items of the same type to have an id that is unique within the
        collection.
      </xs:documentation>
    </xs:annotation>

    <xs:key name="ShellsPointSetIdKey">
      <xs:annotation>
        <xs:documentation>
          ShellsPointSetIdKey collects all ids of points present
          in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:PointSet/t:Point"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ShellsCurve13SetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsCurve13SetIdKey collects all ids of 3D curves
          present in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:Curve13Set/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ShellsSurfaceSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsSurfaceSetIdKey collects all ids of surfaces
          present in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:SurfaceSet/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ShellsVertexSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsVertexSetIdKey collects all ids of vertices present
          in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:VertexSet/t:Vertex"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ShellsEdgeSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsEdgeSetIdKey collects all ids of edges present
          in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:EdgeSet/t:Edge"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ShellsLoopSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsLoopSetIdKey collects all ids of loops present
          in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:LoopSet/t:Loop"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ShellsFaceSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsFaceSetIdKey collects all ids of faces present
          in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:FaceSet/t:Face"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ShellsShellSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsShellSetIdKey collects all ids of shells present
          in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:ShellSet/t:Shell"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ShellsGeometryMeshTriangleIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsGeometryMeshTriangleIdKey collects all ids of triangle
          meshes present in the shell set.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:SurfaceMeshSet/t:MeshTriangle"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ShellsVertexPointKeyref"
      refer="ShellsPointSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsVertexPointKeyref requires that the Id of the Point of
          a Vertex be present in the ShellsPointSetIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:VertexSet/t:Vertex/t:Point/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:keyref name="ShellsEdgeVertexKeyref"
      refer="ShellsVertexSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsEdgeVertexKeyref requires that the Id of the VertexBeg
          and VertexEnd of an edge be present in the ShellsVertexSetIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:EdgeSet/t:Edge/t:VertexBeg/t:Id
             | t:EdgeSet/t:Edge/t:VertexEnd/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:keyref name="ShellsEdgeCurve13Keyref"
      refer="ShellsCurve13SetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsEdgeCurve13Keyref requires that the Id of the Curve of
          an edge be present in the ShellsCurve13SetIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:EdgeSet/t:Edge/t:Curve/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:keyref name="ShellsLoopEdgeKeyref"
      refer="ShellsEdgeSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsLoopEdgeKeyref requires that the Id in an EdgeOriented
          in a CoEdge of a Loop be present in the ShellsEdgeSetIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:LoopSet/t:Loop/t:CoEdges/t:CoEdge/t:EdgeOriented/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:keyref name="ShellsFaceSurfaceKeyref"
      refer="ShellsSurfaceSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsFaceSurfaceKeyref requires that the Id of the Surface
          of a Face be present in the ShellsSurfaceSetIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:FaceSet/t:Face/t:Surface/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:keyref name="ShellsFaceLoopKeyref"
      refer="ShellsLoopSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsFaceLoopKeyref requires that the Id of a Loop
          of a Face be present in the ShellsLoopSetIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:FaceSet/t:Face/t:LoopIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:keyref name="ShellsShellFaceKeyref"
      refer="ShellsFaceSetIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsShellFaceKeyref requires that the Id of a Face
          of a Shell be present in the ShellsFaceSetIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:ShellSet/t:Shell/t:FaceIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

<!-- PathTriangulation connected with MeshTriangle -->

    <xs:keyref name="ShellsGeometrySetPathTriangulationMeshTriangleKeyref"
      refer="ShellsGeometryMeshTriangleIdKey">
      <xs:annotation>
        <xs:documentation>
          The ShellsGeometrySetPathTriangulationMeshTriangleKeyref requires
          that a mesh whose id is specified in a triangulation path curve
          be present in the ShellsGeometryMeshTriangleIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:CurveMeshSet/t:PathTriangulation/t:MeshTriangle/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>
  </xs:element>

<!-- END DEFINITION OF WORKINGCLOSEDSHELLSET ELEMENT -->

