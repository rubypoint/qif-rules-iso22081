  <xs:complexType name="SensorBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The SensorBaseType defines a sensor measurement resource.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="MeasurementResourceBaseType">
        <xs:sequence>
          <xs:element name="ProtectionClass"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ProtectionClass element is the protection
                level of a sensor in the environment.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LinearityError"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LinearityError element is the error in the
                linearity of a sensor. Linearity error is usually specified
                as percentage of Full Scale Output (FSO).
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Repeatability"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Repeatability element is the repeatability of
                a sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Sensitivity"
                      type="xs:double"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Sensitivity element is the sensitivity of
                a sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Resolution"
                      type="LinearValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Resolution element is the resolution of a
                sensor.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LaserType">
