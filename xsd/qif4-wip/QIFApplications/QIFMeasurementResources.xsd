<xs:schema
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns="http://qifstandards.org/xsd/qif4"
  xmlns:t="http://qifstandards.org/xsd/qif4"
  targetNamespace="http://qifstandards.org/xsd/qif4"
  elementFormDefault="qualified"
  attributeFormDefault="unqualified"
  version="4devel.0.17">

  <xs:include schemaLocation="../QIFLibrary/IntermediatesPMI.xsd"/>
  <xs:include schemaLocation="../QIFLibrary/Topology.xsd"/>
  <xs:include schemaLocation="../QIFLibrary/Geometry.xsd"/>
  <xs:include schemaLocation="../QIFLibrary/Traceability.xsd"/>

  <xs:annotation>
    <xs:documentation>
      This QIFMeasurementResources.xsd schema file defines the
      global MeasurementResources element and specific types of
      MeasurementResources.
    </xs:documentation>
  </xs:annotation>

  <xs:element name="MeasurementResources"
              type="MeasurementResourcesType">
    <xs:annotation>
      <xs:documentation>
        The global MeasurementResources element gives information about one
        or more measurement resources (fixtures, measurement devices).
      </xs:documentation>
    </xs:annotation>

<!-- start key and keyref for QIF ids of locations -->

    <xs:key name="MeasurementResourceLocationIdKey">
      <xs:annotation>
        <xs:documentation>
          The MeasurementResourceLocationIdKey collects the QIF ids of all
          Locations of MeasurementResources.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:Fixtures/t:Fixture/t:Locator/t:Location
             | t:MeasurementDevices/t:*/t:Locator/t:Location
             | t:MeasurementDevices/t:*/t:*/t:Locator/t:Location
             | t:Tools/t:*/t:Locator/t:Location
             | t:Tools/t:*/t:*/t:Locator/t:Location
             | t:DetachableSensors/t:*/t:Locator/t:Location"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="MeasurementResourceLocationIdKeyref"
      refer="MeasurementResourceLocationIdKey">
      <xs:annotation>
        <xs:documentation>
          The MeasurementResourceLocationIdKeyref requires that the
          LocationId of a MeasurementResource be present in the
          MeasurementResourceLocationIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:Fixtures/t:Fixture/t:Locator
             | t:MeasurementDevices/t:*/t:Locator
             | t:MeasurementDevices/t:*/t:*/t:Locator
             | t:Tools/t:*/t:Locator
             | t:Tools/t:*/t:*/t:Locator
             | t:DetachableSensors/t:*/t:Locator"/>
      <xs:field xpath="t:LocationId"/>
    </xs:keyref>

<!-- start key and  keyref for QIF ids of tools -->

    <xs:key name="ToolIdKey">
      <xs:annotation>
        <xs:documentation>
          The ToolIdKey collects the QIF ids of all tools in
          MeasurementResources.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:Tools/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ToolIdKeyref"
      refer="ToolIdKey">
      <xs:annotation>
        <xs:documentation>
          The ToolIdKeyref requires that an Id in a ToolIds located
          anywhere in MeasurementResources be present in the ToolIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:MeasurementDevices/t:MultipleCarriageCartesianCMM
              /t:Carriages/t:Carriage/t:ToolIds/t:Id
             | t:MeasurementDevices/t:MultipleCarriageCartesianCMM
              /t:ToolIds/t:Id
             | t:MeasurementDevices/t:CartesianCMM/t:ToolIds/t:Id
             | t:MeasurementDevices/t:ParallelLinkCMM/t:ToolIds/t:Id
             | t:MeasurementDevices/t:ComputedTomographyMachine/t:ToolIds
              /t:Id
             | t:MeasurementDevices/t:Microscope/t:ToolIds/t:Id
             | t:MeasurementDevices/t:UniversalLengthMeasuring/t:ToolIds
              /t:Id
             | t:MeasurementDevices/t:OpticalComparator/t:ToolIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

<!-- start key and keyref for QIF ids of detachable sensors -->

    <xs:key name="DetachableSensorIdKey">
      <xs:annotation>
        <xs:documentation>
          The DetachableSensorIdKey collects the QIF ids of all detachable
          sensors in MeasurementResources.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:DetachableSensors/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="DetachableSensorIdKeyref"
      refer="DetachableSensorIdKey">
      <xs:annotation>
        <xs:documentation>
          The DetachableSensorIdKeyref requires that an Id in a SensorIds
          located anywhere in MeasurementResources be present in the
          DetachableSensorIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:Tools/t:ToolWithDetachableSensors/t:SensorIds/t:Id
             | t:MeasurementDevices/t:CartesianCMM/t:SensorIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>
  </xs:element>

<!-- END KEYS AND KEYREFS FOR MEASUREMENT RESOURCES -->

<!-- BEGIN MEASUREMENT RESOURCE TYPES -->

  <xs:complexType name="MeasurementResourcesType">
    <xs:annotation>
      <xs:documentation>
        The MeasurementResourcesType defines a set of measurement
        resources.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Version"
                  type="VersionType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Version element uniquely identifies the version
            information of this QIF Resources instance.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Fixtures"
                  type="FixturesType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Fixtures element is a list of fixtures.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NominalEnvironments"
                  type="NominalEnvironmentsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NominalEnvironments element is a list of nominal
            environments.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MeasurementRooms"
                  type="MeasurementRoomsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional MeasurementRooms element is a list of measurement
            rooms.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MeasurementDevices"
                  type="MeasurementDevicesType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional MeasurementDevices element is a list of
            measurement devices.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DetachableSensors"
                  type="DetachableSensorsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DetachableSensors element is a list of detachable
            sensors.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Tools"
                  type="ToolsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Tools element is a list of tools.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DigitalCalibrationCertificates"
                  type="DigitalCalibrationCertificatesType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DigitalCalibrationCertificates element is a list
            of calibration certificates.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DigitalCalibrationCertificatesType">
    <xs:annotation>
      <xs:documentation>
        The DigitalCalibrationCertificatesType defines a set of digital 
        calibration certificates.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="DigitalCalibrationCertificate"
                  type="DigitalCalibrationCertificateType"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each DigitalCalibrationCertificate element is a definition of 
            a digital calibration certificate.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of digital calibration 
          certificates in the list.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="DigitalCalibrationCertificateType">
    <xs:annotation>
      <xs:documentation>
        The DigitalCalibrationCertificateType defines a single digital 
        calibration certificate.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="CalibrationHeader"
                  type="CalibrationHeaderType">
        <xs:annotation>
          <xs:documentation>
            The CalibrationHeader element defines information that 
            applies or is available to the entire calibration certificate. 
            It includes (but is not limited to) information about 
            relevant organizations, items tested, calibration statements, 
            and inspecting organization accreditations.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CalibrationResultSet"
                  type="CalibrationResultSetType">
        <xs:annotation>
          <xs:documentation>
            The required CalibrationResultSet element is a list of 
            calibration results.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Signature"
                  type="UserDataXMLType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Signature element is as defined in the 
            XML-Signature Syntax and Processing W3C Recommendation 12 
            February 2002. 
            http://www.w3.org/TR/2002/REC-xmldsig-core-20020212
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="id"
                  type="QIFIdType">
      <xs:annotation>
        <xs:documentation>
          The required id attribute is the QIF id of the digital 
          calibration certificate, used for referencing.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="CalibrationHeaderType">
    <xs:annotation>
      <xs:documentation>
        The CalibrationHeaderType defines information that applies or 
        is available to the entire calibration certificate. It 
        includes (but is not limited to) information about relevant 
        organizations, items tested, calibration statements, 
        and inspecting organization accreditations.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Description"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Description element is a description of this
            calibration certificate.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InternalDocumentID"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional InternalDocumentID element is intended to
            retain the organization-specific identification number of
            the report or calibration certificate.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DocumentUUID"
                  type="UUIDAssignmentType">
        <xs:annotation>
          <xs:documentation>
            The required DocumentUUID element contains the universally
            unique identifier of the report or calibration certificate.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DateReportIssued"
                  type="xs:dateTime"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DateReportIssued element contains the date and
            time that the report or calibration certificate was issued.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DateOfItemsReceipt"
                  type="xs:dateTime"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DateOfItemsReceipt element contains the date
            and time that the inspecting organization recieved the item
            or items to be tested.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InspectingOrganization"
                  type="OrganizationType">
        <xs:annotation>
          <xs:documentation>
            The required InspectingOrganization element contains
            information about the organization inspecting the artifact
            and issuing the report or calibration certificate.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CustomerOrganization"
                  type="OrganizationType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CustomerOrganization element contains
            information about the organization requesting the
            calibration or inspection.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InspectingOrganizationAccreditations"
                  type="InspectingOrganizationAccreditationsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional InspectingOrganizationAccreditations element
            is a list of individual inspecting organization accreditations.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ItemsTested"
                  type="ItemsTestedType">
        <xs:annotation>
          <xs:documentation>
            The required ItemsTested element is a list of items tested 
            during the calibration process.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DocumentaryStandardsReferenced"
                  type="StandardsOrSectionsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DocumentaryStandardsReferenced element is a 
            list of standards referenced in the calibration of the item 
            tested. 
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CalibrationStatements"
                  type="CalibrationStatementsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CalibrationStatements element is a list of 
            calibration statements.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ReferenceStandardArtifacts"
                  type="ReferenceStandardArtifactsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ReferenceStandardArtifacts element is a list of
            standard artifacts used in the calibration process.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PersonAuthorizingReport"
                  type="EmployeeType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional PersonAuthorizingReport element identifies the
            person who authorized issuing the calibration certificate.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CertificateUnits"
                  type="FileUnitsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CertificateUnits element gives the units for
            this calibration certificate. If used, this element overrides
            any units given for the file as a whole.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ItemTestedType">
    <xs:annotation>
      <xs:documentation>
        The ItemTestedType defines information about a single item tested 
        in the calibration process.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Name"
                  type="xs:token">
        <xs:annotation>
          <xs:documentation>
            The required Name element is the name of the item being 
            tested.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Description"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Description element is a plain text description 
            of the item being tested.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Manufacturer"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Manufacturer element is the name of the item's 
            manufacturer.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ModelNumber"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ModelNumber element is the model number of the 
            item tested.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SerialNumber"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional SerialNumber element is the serial number of the 
            item tested.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LocationDescription"
                  type="xs:token"
                  minOccurs="0"
                  maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            The optional LocationDescription element is a plain text 
            description of the item's location.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PreInspectionCondition"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional PreInspectionCondition element is a plain text 
            description of the item's condition before inspection.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PreviousCalibrationCertificateId"
                  type="QIFReferenceBaseType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional PreviousCalibrationCertificateId is the QIF id of 
            the item's previous calibration certificate.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QIFResourceIds"
                  type="ArrayReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional QIFResourceIds element is a list of QIF
            measurement resource IDs associated with the item or items
            being tested.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="id"
                  type="QIFIdType">
      <xs:annotation>
        <xs:documentation>
          The required id attribute is the QIF id of the item tested, 
          used for referencing.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="ItemsTestedType">
    <xs:annotation>
      <xs:documentation>
        The ItemsTestedType is a list of items tested during the 
        calibration process.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ItemTested"
                  type="ItemTestedType"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each ItemTested element defines information about a single item
            tested in the calibration process.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of items tested in the 
          list.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="ReferenceStandardArtifactType">
    <xs:annotation>
      <xs:documentation>
        The ReferenceStandardArtifactType defines an individual reference 
        standard artifact used to calibrate an item tested.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Description"
                  type="xs:token"
                  minOccurs="1">
        <xs:annotation>
          <xs:documentation>
            The required Description element is a plain text description 
            of the reference standard artifact.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ModelNumber"
                  type="xs:token"
                  minOccurs="0"
                  maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            The optional ModelNumber element is the model number of the 
            reference standard artifact.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SerialNumber"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional SerialNumber element is the serial number of the 
            reference standard artifact.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InternalReferenceID"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional InternalReferenceID element is an identifier for 
            the reference standard artifact. This identifier is typically 
            for inspecting organization internal use.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CalibrationDate"
                  type="xs:dateTime"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CalibrationDate element is the date that the 
            reference standard artifact was last calibrated.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CalibrationDueDate"
                  type="xs:dateTime"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CalibrationDueDate element is the date that the 
            reference standard artifact is due to be recalibrated.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CalibrationCertificateReferenceId"
                  type="QIFReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CalibrationCertificateReferenceId is the QIF id 
            associated with a calibration certificate for the reference 
            standard artifact. This should be the active certificate for 
            the artifact at the time of calibration, if possible.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="id"
                  type="QIFIdType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required id attribute is the QIF id of the reference 
          standard artifact.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="ReferenceStandardArtifactsType">
    <xs:annotation>
      <xs:documentation>
        The ReferenceStandardArtifactsType defines a list of standard 
        artifacts used in the calibration process.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ReferenceStandardArtifact"
                  type="ReferenceStandardArtifactType"
                  minOccurs="1"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each ReferenceStandardArtifact element represents an 
            individual reference standard artifact used to calibrate an 
            item tested.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of reference standard 
          artifacts in the list.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="CalibrationResultSetType">
    <xs:annotation>
      <xs:documentation>
        The CalibrationResultSetType defines a list of individual 
        calibration results.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence maxOccurs="1">
      <xs:element name="CalibrationResult"
                  type="CalibrationResultType"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each CalibrationResult element is an individual calibration 
            result, each with a single inspection status. Optionally, it 
            may contain a single nominal value, a single 'as found' 
            value, and a single numerical result value among other things.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of calibration results in 
          the list.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="NotedCalibrationEventsType">
    <xs:annotation>
      <xs:documentation>
        The NotedCalibrationEventsType defines a list of events that
        occurred during the calibration procedure that could influence the
        result.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="NotedCalibrationEvent"
                  type="NotedCalibrationEventType"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each NotedCalibrationEvent element describes a single event
            that occurred during the calibration procedure that could
            influence the result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of noted calibration
          events in the list.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="NotedCalibrationEventType">
    <xs:annotation>
      <xs:documentation>
        The NotedCalibrationEventType defines a single event that occurred
        during the calibration procedure that could influence the result.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="NotedCalibrationEventDateTime"
                  type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>
            The required NotedCalibrationEventDateTime element is the date
            and time that the noted calibration event occurred.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NotedCalibrationEventString"
                  type="xs:token">
        <xs:annotation>
          <xs:documentation>
            The required NotedCalibrationEventString is a plain text
            description of the noted calibration event.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="EventNotability"
                  type="EventNotabilityEnumType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional EventNotability element describes how notable the
            calibration event was.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="CalibrationStatementsType">
    <xs:annotation>
      <xs:documentation>
        The CalibrationStatementsType defines a list of calibration 
        statements.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence maxOccurs="unbounded">
      <xs:element name="CalibrationStatement"
                  type="CalibrationStatementType">
        <xs:annotation>
          <xs:documentation>
            Each CalibrationStatement element is an individual 
            calibration statement such as an uncertainty statement, 
            statement of conformity, statement of traceability, 
            or statement of applicability. 
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of calibration 
          statements in the list. 
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="CalibrationStatementType">
    <xs:annotation>
      <xs:documentation>
        The CalibrationStatementType defines an individual calibration 
        statement. This could be an uncertainty statement, statement of 
        conformity, statement of traceability, or statement of 
        applicability. 
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="TypeOfCalibrationStatement"
                  type="TypeOfCalibrationStatementEnumType">
        <xs:annotation>
          <xs:documentation>
            The required TypeOfCalibrationStatement element describes 
            which type of calibration statement is being defined.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CalibrationStatementText"
                  type="xs:token">
        <xs:annotation>
          <xs:documentation>
            The required CalibrationStatementText element is the plain 
            text calibration statement.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="StandardOrSectionId"
                  minOccurs="0"
                  maxOccurs="unbounded"/>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="NumericalResultType">
    <xs:annotation>
      <xs:documentation>
        The NumericalResultType defines a generic numerical nominal value 
        or measurement result.
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:double">
        <xs:attribute name="unit"
                      type="xs:string">
          <xs:annotation>
            <xs:documentation>
              The optional unit attribute defines the unit used by the 
              nominal value or numerical result.
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="UncertaintyType">
    <xs:annotation>
      <xs:documentation>
        The UncertaintyType defines the measurement uncertainty 
        associated with a calibration.
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:double">
        <xs:attribute name="unit"
                      type="xs:string">
          <xs:annotation>
            <xs:documentation>
              The optional unit attribute defines the uncertainty units.
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="DecisionRuleType">
    <xs:annotation>
      <xs:documentation>
        The DecisionRuleType defines information about the rules used to 
        determine the inspection status from the numerical measurement 
        results.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="TypeOfDecisionRule"
                  type="TypeOfDecisionRuleEnumType"
                  maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            The required TypeOfDecisionRule element is used to describe 
            which decision rule was used to determine the inspection 
            status. The enumerations are described in ILAC-G8:09/2019.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UpperSpecificationLimit"
                  type="xs:double"
                  minOccurs="0"
                  maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            The optional UpperSpecificationLimit element is the maximum 
            allowable true value of the quantity associated with the 
            calibration result. This value is also the upper tolerance 
            limit.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LowerSpecificationLimit"
                  type="xs:double"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional LowerSpecificationLimit element is the minimum 
            allowable true value of the quantity associated with the 
            calibration result. This value is also the lower tolerance 
            limit.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UpperAcceptanceLimit"
                  type="xs:double"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional UpperAcceptanceLimit element is the maximum 
            allowable value of the numerical calibration result that will 
            cause a passed inspection.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LowerAcceptanceLimit"
                  type="xs:double"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional LowerAcceptanceLimit element is the minimum 
            allowable value of the numerical calibration result that will 
            cause a passed inspection.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OtherDecisionRuleText"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional OtherDecisionRuleText element contains a free 
            text description of a special decision rule not otherwise 
            represented.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="CalibrationResultType">
    <xs:annotation>
      <xs:documentation>
        The CalibrationResultType defines an individual calibration 
        result, each with a single inspection status. Optionally, it may 
        contain a single nominal value, a single 'as found' value, and a 
        single numerical result value among other things.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Description"
                  type="xs:token">
        <xs:annotation>
          <xs:documentation>
            The required Description element is a plain text description 
            of the calibration result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CalibrationResultsDateTime"
                  type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>
            The required CalibrationResultsDateTime element is the date 
            and time that the calibration result was generated.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ItemTestedId"
                  type="QIFReferenceBaseType">
        <xs:annotation>
          <xs:documentation>
            The required ItemTestedId element is the QIF id of the 
            'item tested' associated with the calibration result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InspectionStatus"
                  type="InspectionStatusEnumType">
        <xs:annotation>
          <xs:documentation>
            The required InspectionStatus element describes the status 
            of the calibration result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NominalValue"
                  type="NumericalResultType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NominalValue element is the nominal numerical 
            value associated with the measurement result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NumericalAsFound"
                  type="NumericalResultType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NumericalAsFound element is the result of a 
            measurement conducted before any corrective action is taken. 
            The 'as found' value can equal the numerical result if no 
            corrective action is taken during the calibration process.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NumericalResult"
                  type="NumericalResultType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NumericalResult element is the final numerical 
            measurement result associated with the calibration result. 
            The numerical result is also known as an "as left" value.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Uncertainty"
                  type="UncertaintyType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Uncertainty element describes the measurement 
            uncertainty associated with the calibration.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DecisionRule"
                  type="DecisionRuleType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional DecisionRule element contains information about
            the rules used to determine the inspection status from the
            numerical measurement results.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ResultProvider"
                  type="ResultProviderType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ResultProvider element describes who provided the
            calibration result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DateOfSampling"
                  type="xs:dateTime"
                  minOccurs="0"
                  maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            The optional DateOfSampling element is the date that sampling
            occurred or measurements were taken.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MethodOrSamplingPlanReferences"
                  type="ArrayReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional MethodOrSamplingPlanReferences element is a list
            of QIF ids that refer to method or sampling plans listed in
            ExternalReferences.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MethodOrSamplingPlanText"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional MethodOrSamplingPlanText element is a plain text
            description of the method or sampling plan used to arrive at
            the calibration result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PlantLocation"
                  type="LocationType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional PlantLocation element is a description of the
            location of calibration activities.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MeasuredAmbientEnvironment"
                  type="MeasuredEnvironmentType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional MeasuredAmbientEnvironment element is the measured
            environmental conditions present at the time calibration
            activities are conducted.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NominalAmbientEnvironmentId"
                  type="QIFReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NominalAmbientEnvironmentId element is the QIF id
            of nominal or normal environmental conditions present at the
            time calibration activities are conducted.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NotedCalibrationEvents"
                  type="NotedCalibrationEventsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NotedCalibrationEvents element is a list of events
            that occurred during the calibration procedure that could
            influence the result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OpinionsAndInterpretations"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional OpinionsAndInterpretations element is a location
            provided to give plain text 'opinions and interpretations' of
            the calibration result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="InspectingOrganizationAccreditationsType">
    <xs:annotation>
      <xs:documentation>
        The InspectingOrganizationAccreditationsType is a list of
        individual inspecting organization accreditations.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="InspectingOrganizationAccreditation"
                  type="InspectingOrganizationAccreditationType"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each InspectingOrganizationAccreditation element
            contains information about the inspecting organization's
            accreditations.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of accreditations in the
          list.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="InspectingOrganizationAccreditationType">
    <xs:annotation>
      <xs:documentation>
        The InspectingOrganizationAccreditationType defines information
        about the inspecting organization's accreditations.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="AccreditationOrganization"
                  type="OrganizationType">
        <xs:annotation>
          <xs:documentation>
            The required AccreditationOrganization element contains
            information about the organization that provides accreditation
            to the inspecting organization.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccreditationSymbolImageFileReference"
                  type="OtherFileOrWebReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AccreditationSymbolImageFileReference provides
            information about the controlled accreditation symbol image
            provided from the accreditating organization to the inspecting
            organization.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccreditationProgramOrField"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AccreditationProgramOrField element contains
            information about what types of inspections the inspecting
            organization is accredited to perform. Examples include
            calibration, electromagnetic testing, etc.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccreditationCertificateNumber"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AccreditationCertificateNumber element contains
            the certificate number of the accreditation described.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ResultProviderType">
    <xs:annotation>
      <xs:documentation>
        The ResultProviderType defines information about who provided the
        calibration result.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ResultProviderInternalExternal"
                  type="ResultProviderInternalExternalEnumType">
        <xs:annotation>
          <xs:documentation>
            The required ResultProviderInternalExternal element describes
            whether the calibration result is provided by the same
            organization that generated the calibration certificate
            (Internal). Otherwise, if the calibration result was provided
            by an external organization, the 'External' enumeration should
            be chosen.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ResultProviderName"
                  type="xs:token"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ResultProviderName element is the name of the
            person or organization who generated the calibration result.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:simpleType name="ResultProviderInternalExternalEnumType">
    <xs:annotation>
      <xs:documentation>
        The ResultProviderInternalExternalEnumType enumerates values that
        describe whether the calibration result was generated internally,
        within the organization, or externally, outside of the organization
        that is creating the digital calibration certificate.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:token">
      <xs:enumeration value="Internal"/>
      <xs:enumeration value="External"/>
      <xs:enumeration value="Unspecified"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="TypeOfCalibrationStatementEnumType">
    <xs:annotation>
      <xs:documentation>
        The TypeOfCalibrationStatementEnumType enumerates values that
        describe what type of calibration statement is being defined.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:token">
      <xs:enumeration value="StatementOfTraceability"/>
      <xs:enumeration value="StatementOfConformity"/>
      <xs:enumeration value="StatementOfApplicability"/>
      <xs:enumeration value="UncertaintyStatement"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="TypeOfDecisionRuleEnumType">
    <xs:annotation>
      <xs:documentation>
        The TypeOfDecisionRuleEnumType enumerates values that describe
        which decision rule was used to determine the inspection status.
        The enumerations are described in ILAC-G8:09/2019.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:token">
      <xs:enumeration value="BinaryStatementWithSimpleAcceptance"/>
      <xs:enumeration value="BinaryStatementWithGuardBand"/>
      <xs:enumeration value="NonBinaryStatement"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="EventNotabilityEnumType">
    <xs:annotation>
      <xs:documentation>
        The EventNotabilityEnumType enumerates how notable the calibration
        event was.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:token">
      <xs:enumeration value="HighlyNotable"/>
      <xs:enumeration value="ModeratelyNotable"/>
      <xs:enumeration value="NegligiblyNotable"/>
      <xs:enumeration value="UnknownNotability"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="LocatorType">
    <xs:annotation>
      <xs:documentation>
        The LocatorType provides a choice of either a location
        or a reference to a location.
      </xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="LocationId"
                  type="QIFReferenceType">
        <xs:annotation>
          <xs:documentation>
            The LocationId element is the QIF id of the location of the
            measurement device. This element is in an optional choice.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Location"
                  type="LocationType">
        <xs:annotation>
          <xs:documentation>
            The Location element gives information about the location of
            the measurement resource. This element is in an optional
            choice.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="MeasurementResourceBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract MeasurementResourceBaseType is the base type for
        measurement resources that may be required by an action, used by a
        method, or referenced. Resource types may be a fixture, a carriage,
        a measurement device, a tool, a sensor, or a probe tip.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Name"
                  type="xs:string">
        <xs:annotation>
          <xs:documentation>
            The Name element is the name of the measurement resource.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Description"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Description element is a description of the
            measurement resource.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Manufacturer"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Manufacturer element is the manufacturer of the
            measurement resource.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ModelNumber"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ModelNumber element is the identifier of a
            very specific type of measurement resource. There may be
            many measurement resources with the same ModelNumber, but
            they should all be identical (or nearly so).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SerialNumber"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional SerialNumber element is the serial number of
            the measurement resource. Measurement resources with the
            same ModelNumber have different SerialNumbers. The
            combination of ModelNumber and SerialNumber should
            differentiate a given measurement resource from all other
            measurement resources in a QIF application instance file.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Mass"
                  type="MassValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Mass element is the mass of the measurement
            resource.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Size"
                  type="CartesianWorkingVolumeType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Size element is the size of a measurement
            resource. The size is defined as a box having X, Y, and Z
            dimensions.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Locator"
                  type="LocatorType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Locator element provides a choice of either a
            location or a reference to a location.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NominalEnvironmentIds"
                  type="ArrayReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NominalEnvironmentIds element is a list of the
            QIF ids of nominal environments in which the resource may be
            used for producing usable measurements.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CalibrationCertificateIds"
                  type="ArrayReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CalibrationCertificateIds element is a
            list of the QIF ids of calibration certificates for
            the resource.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="id"
                  type="QIFIdType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required id attribute is the QIF id of the measurement
          resource, used for referencing.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

