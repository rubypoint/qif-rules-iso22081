  <xs:element name="HeightGage"
              type="HeightGageType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global HeightGage element gives information about a height
        gage, a device used to determine the linear distance between
        a surface plate and the top of an object.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="SingleEndPinGage"
              type="SingleEndPinGageType"
              substitutionGroup="MeasurementDevice">
    <xs:annotation>
      <xs:documentation>
        The global SingleEndPinGage element gives information about
        an unthreaded single diameter pin gage device.
