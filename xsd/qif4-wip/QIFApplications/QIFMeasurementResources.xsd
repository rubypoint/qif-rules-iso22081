  <xs:complexType name="NominalEnvironmentType">
    <xs:annotation>
      <xs:documentation>
        The NominalEnvironmentType defines an environment with tolerances.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Name"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Name element is the name of the nominal
            environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Description"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Description element is a description of the
            nominal environmental.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TemperatureTarget"
                  type="TemperatureValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional TemperatureTarget element is the desired
            ambient temperature of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TemperatureMin"
                  type="TemperatureValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional TemperatureMin element is the minimum ambient
            temperature of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TemperatureMax"
                  type="TemperatureValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional TemperatureMax element is the maximum ambient
            temperature of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="RelativeHumidityTarget"
                  type="FractionType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional RelativeHumidityTarget element is the desired
            relative humidity of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="RelativeHumidityMin"
                  type="FractionType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional RelativeHumidityMin element is the minimum
            relative humidity of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="RelativeHumidityMax"
                  type="FractionType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional RelativeHumidityMax element is the maximum
            relative humidity of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AmbientAirPressureTarget"
                  type="PressureValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AmbientAirPressureTarget element is the desired
            ambient air pressure of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AmbientAirPressureMax"
                  type="PressureValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AmbientAirPressureMax element is the maximum
            ambient air pressure of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AmbientAirPressureMin"
                  type="PressureValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AmbientAirPressureMin element is the minimum
            ambient air pressure of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AmbientIlluminanceTarget"
                  type="IlluminanceValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AmbientIlluminanceTarget element is the desired
            ambient illuminance of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AmbientIlluminanceMax"
                  type="IlluminanceValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AmbientIlluminanceMax element is the maximum
            ambient illuminance of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AmbientIlluminanceMin"
                  type="IlluminanceValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AmbientIlluminanceMin element is the minimum
            ambient illuminance of the environment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MaxVibration"
                  type="UserDefinedUnitValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional MaxVibration element is the maximum vibration of
            the environment. The minimum and target are zero.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="id"
                  type="QIFIdType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required id attribute is the QIF id of the nominal
          environment, used for referencing.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="NominalEnvironmentsType">
    <xs:annotation>
      <xs:documentation>
        The NominalEnvironmentsType is a list of nominal environments.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="NominalEnvironment"
                  type="NominalEnvironmentType"
                  maxOccurs="unbounded">
        <xs:annotation>
