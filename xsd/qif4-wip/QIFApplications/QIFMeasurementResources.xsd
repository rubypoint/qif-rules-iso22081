              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LaserPower"
                      type="UserDefinedUnitValueType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LaserPower element is the laser output power.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LaserSafetyClass"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional LaserSafetyClass element is the safety class
