              <xs:documentation>
                The optional FeatureZoneIds element contains ids of
                feature zones of the part or assembly for the folder.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CharacteristicNominalIds"
                      type="ArrayReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CharacteristicNominalIds element contains
                ids of characteristic nominals of the part or assembly
                for the folder.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NoteIds"
                      type="ArrayReferenceFullType"
                      minOccurs="0">
