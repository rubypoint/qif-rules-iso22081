          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of parts in this set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="AssemblySetType">
    <xs:annotation>
      <xs:documentation>
        The AssemblySetType represents a container for storing all
        assemblies present in the product.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="Assembly"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each Assembly element is an assembly which may be used
            by a number of components (instances of the assembly).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of assemblies in this set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:element name="PartSet"
              type="PartSetType">
    <xs:annotation>
      <xs:documentation>
        The global PartSet element is a collection of all parts
        present in the product.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="AssemblySet"
              type="AssemblySetType">
    <xs:annotation>
      <xs:documentation>
        The global AssemblySet element is a collection of all assemblies
        present in the product.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="ComponentType">
    <xs:annotation>
      <xs:documentation>
        The ComponentType defines a single instance of a part
        or an assembly.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="DrawableBaseType">
        <xs:sequence>
          <xs:element name="Transform"
                      type="ElementReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Transform element is an identifier of the
                transformation matrix that maps the component into the
                product.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="UUID"
                      type="UUIDChoiceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional UUID element is a persistent identifier
                for the component. If a new UUID is assigned, it shall
                be generated using a widely accepted UUID generator.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Traceability"
                      type="ProductTraceabilityType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Traceability element gives traceability
                information for a component.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:choice>
            <xs:element name="Part"
                        type="ElementReferenceType">
              <xs:annotation>
                <xs:documentation>
                  The Part element is an identifier of a part
                  to be instantiated.
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="Assembly"
                        type="ElementReferenceType">
              <xs:annotation>
                <xs:documentation>
                  The Assembly element is an identifier of an assembly
                  to be instantiated.
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:choice>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:element name="Component"
              type="ComponentType">
    <xs:annotation>
      <xs:documentation>
        The global Component element is an instance of a part template.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="ComponentSetType">
    <xs:annotation>
      <xs:documentation>
        The ComponentSetType represents a container for storing all
        components present in the product.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="Component"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each Component element is an instance of a part template.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of components in this set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:element name="ComponentSet"
              type="ComponentSetType">
    <xs:annotation>
      <xs:documentation>
        The global ComponentSet element is a collection of all components
        present in the product.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="DefinitionsExternalType">
    <xs:annotation>
      <xs:documentation>
        The DefinitionsExternalType defines the geometry of a product
        (a part or an assembly) in various degrees of detail.
      </xs:documentation>
    </xs:annotation>
    <xs:choice maxOccurs="unbounded">
      <xs:annotation>
        <xs:documentation>
          This compositor provides a choice among types of drawing and
          types of model.
        </xs:documentation>
      </xs:annotation>
      <xs:element name="PrintedDrawingId"
                  type="QIFReferenceType">
        <xs:annotation>
          <xs:documentation>
            The PrintedDrawingId element is the QIF id of a printed drawing
            described in the PrintedDrawingReferences of this document.
            This element is in an optional choice.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DigitalDrawingId"
                  type="QIFReferenceType">
        <xs:annotation>
          <xs:documentation>
            The DigitalDrawingId element is the QIF id of a digital
            drawing described in the DigitalDrawingReferences of this
            document. This element is in an optional choice.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DigitalModelId"
                  type="QIFReferenceType">
        <xs:annotation>
          <xs:documentation>
            The DigitalModelId element is the QIF id of a digital
            model described in the DigitalModelReferences of this
            document. This element is in an optional choice.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PhysicalModelId"
                  type="QIFReferenceType">
        <xs:annotation>
          <xs:documentation>
            The PhysicalModelId element is the QIF id of a physical
            model described in the PhysicalModelReferences of this
            document. This element is in an optional choice.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:choice>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of external product
          definitions in this list.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="PartAssemblyHeaderType">
    <xs:annotation>
      <xs:documentation>
        The PartAssemblyHeaderType gives a variety of information about
        the part or assembly.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Name"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Name element is the name of the part or assembly.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ApplicationSourcePartAssemblyName"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ApplicationSourcePartAssemblyName element
            is the name of the part or assembly as given in the
            application source file.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Description"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Description element is a description of the
            part or assembly.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ExternalReferenceId"
                  type="QIFReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ExternalReferenceId element is the QIF id of an
            external reference (such as a file defining the model) in
            the ExternalReferences of the QIFDocument used in the model.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ConfigurationName"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ConfigurationName element is the name of a part
            configuration.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Tolerance"
                  type="LinearValueType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Tolerance element is the smallest distance
            between coordinates in a part or assembly that shall be
            considered as distinct.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ProductHeaderType">
    <xs:annotation>
      <xs:documentation>
        The ProductHeaderType provides general information about the
        product. It includes reference to an external model of the
        product and gives global parameters of the model.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Name"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Name element is the name of the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Description"
                  type="xs:string"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Description element is a description of the
            product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ExternalReferenceId"
                  type="QIFReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ExternalReferenceId element is the QIF id of
            an external reference in the ExternalReferences of the
            QIFDocument used in defining the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ScaleCoefficient"
                  type="xs:double"
                  default="1.0"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ScaleCoefficient element is an amount by
            which all elements representing distances in the
            QIFDocument/QIFProduct and QIFDocument/Features portions
            of an instance file are scaled. The default value is 1.The
            type of all values to be scaled is either LinearValueType
            or xs:double. To convert such values in an instance file
            to actual values, divide by the ScaleCoefficient. To
            record actual values in an instance file, multiply the
            actual value by the ScaleCoefficient.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MassPropertyTolerance"
                  type="xs:double"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional MassPropertyTolerance element specifies a
            tolerance used for calculation of the mass properties
            of model entities.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="LayerType">
    <xs:annotation>
      <xs:documentation>
        The LayerType is the type which represents one of the model
        "grouping" objects.
          NOTE1: The user may specify arbitrary number of layers for
                 one model.
          NOTE2: Any model entity may be included in an arbitrary number
                 of layers.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="DrawableBaseType">
        <xs:sequence>
          <xs:element name="ElementIds"
                      type="ArrayReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ElementIds element is an array of entity
                identifiers present in this layer.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
        <xs:attribute name="applyColor"
                      type="xs:boolean"
                      default="0">
          <xs:annotation>
            <xs:documentation>
              The optional applyColor attribute shows if the layer color
              supersedes colors of the model entities associated with this
              layer. The default value is FALSE.
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
        <xs:attribute name="index"
                      type="xs:unsignedInt"
                      use="required">
          <xs:annotation>
            <xs:documentation>
              The required index attribute defines the layer index.
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="LayerSetType">
    <xs:annotation>
      <xs:documentation>
        The LayerSetType represents a container for storing all
        layers present in the product.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="Layer"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            The Layer element defines the model layer with associated model
            entities stored in the direct references.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of layers in this set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:element name="Layer"
              type="LayerType">
    <xs:annotation>
      <xs:documentation>
        The global Layer element defines the model layer with associated
        model entities stored in the direct references.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="LayerSet"
              type="LayerSetType">
    <xs:annotation>
      <xs:documentation>
        The global LayerSet element is a collection of all model layers.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="PartNoteSetType">
    <xs:annotation>
      <xs:documentation>
        The PartNoteSetType represents a container for storing all
        part notes present in the product.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="PartNote"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each PartNote element is a part note.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of part notes in this set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="PartNoteType">
    <xs:annotation>
      <xs:documentation>
        The PartNoteType represents a note about a part.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="DrawableBaseType">
        <xs:sequence>
          <xs:element name="Text"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Text element is the text of the PartNote.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PartNoteIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional PartNoteIds element is an array of identifiers
                of nested part notes.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Indicator"
                      type="IndicatorType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Indicator element is an indicator
                for the part note.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="NoteType">
    <xs:annotation>
      <xs:documentation>
        The NoteType represents a note, also called a standard note.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="DrawableBaseType">
        <xs:sequence>
          <xs:element name="FeatureCounter"
                      type="xs:unsignedInt"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FeatureCounter element indicates the number
                of associated features.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FeatureNominalIds"
                      type="ArrayReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FeatureNominalIds element is a list of the QIF
                ids of features associated with this note.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Text"
                      type="xs:string">
            <xs:annotation>
              <xs:documentation>
                The Text element is the text of the Note.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Indicator"
                      type="IndicatorType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Indicator element is an indicator
                for the note.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
        <xs:attribute name="form"
                      type="NoteFormEnumType"
                      default="3D">
          <xs:annotation>
            <xs:documentation>
              The form attribute specifies how the Note is represented.
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:simpleType name="NoteFormEnumType">
    <xs:annotation>
      <xs:documentation>
        The NoteFormEnumType enumerates values that describe the form
        of the Note and may be the following values:
          `3D` - Note defined on the 3D annotation plane;
          `SCREEN` - Note defined as flat to screen;
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:token">
      <xs:enumeration value="3D"/>
      <xs:enumeration value="SCREEN"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:complexType name="NoteSetType">
    <xs:annotation>
      <xs:documentation>
        The NoteSetType represents a set of notes.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="Note"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each Note element is a note.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of notes in this set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="NoteFlagType">
    <xs:annotation>
      <xs:documentation>
        The NoteFlagType represents a flag note.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="DrawableBaseType">
        <xs:sequence>
          <xs:element name="FeatureCounter"
                      type="xs:unsignedInt"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FeatureCounter element indicates the number
                of associated features.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FeatureNominalIds"
                      type="ArrayReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FeatureNominalIds element is a list of the QIF
                ids of features associated with this flag note.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Text"
                      type="xs:string">
            <xs:annotation>
              <xs:documentation>
                The Text element is the text of the flag note.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TextHidden"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional TextHidden element is the hidden text of the
                flag note.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ExternalReferenceWithURIId"
                      type="QIFReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ExternalReferenceWithURIId element is the
                QIF id of an OtherFileOrWebReference that includes a
                Uniform Resource Identifier for the information.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
        <xs:attribute name="form"
                      type="NoteFormEnumType"
                      default="3D">
          <xs:annotation>
            <xs:documentation>
              The form attribute specifies how the flag note is represented.
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="NoteFlagSetType">
    <xs:annotation>
      <xs:documentation>
        The NoteFlagSetType represents a set of flag notes.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="NoteFlag"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each NoteFlag element is a flag note.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of flag notes in this set.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:element name="PartNoteSet"
              type="PartNoteSetType">
    <xs:annotation>
      <xs:documentation>
        The global PartNoteSet element is a collection of all part notes
        and standard notes presented in the product.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="PartNote"
              type="PartNoteType">
    <xs:annotation>
      <xs:documentation>
        The global PartNote element is a part note or standard note.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="NoteSet"
              type="NoteSetType">
    <xs:annotation>
      <xs:documentation>
        The global NoteSet element is a collection of all notes
        presented in the product.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="Note"
              type="NoteType">
    <xs:annotation>
      <xs:documentation>
        The global Note element is a note.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="NoteFlagSet"
              type="NoteFlagSetType">
    <xs:annotation>
      <xs:documentation>
        The global NoteFlagSet element is a collection of all flag
        notes presented in the product.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="NoteFlag"
              type="NoteFlagType">
    <xs:annotation>
      <xs:documentation>
        The global NoteFlag element is a flag note.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="FoldersPart"
              type="FoldersPartType">
    <xs:annotation>
      <xs:documentation>
        The global FoldersPart element is a folder tree of the part.
      </xs:documentation>
    </xs:annotation>

    <xs:key name="FoldersPartFolderIdKey">
      <xs:annotation>
        <xs:documentation>
          The FoldersPartFolderIdKey collects all folder ids.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:FolderPart"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="FoldersPartFolderIdKeyref"
      refer="FoldersPartFolderIdKey">
      <xs:annotation>
        <xs:documentation>
          The FoldersPartFolderIdKeyref requires that Ids in the
          FolderIds of a FolderPart be present in the
          FoldersPartFolderIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:FolderPart/t:FolderIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>
  </xs:element>

  <xs:element name="FoldersAssembly"
              type="FoldersAssemblyType">
    <xs:annotation>
      <xs:documentation>
        The global FoldersAssembly element is a folder tree of the assembly.
      </xs:documentation>
    </xs:annotation>

    <xs:key name="FoldersAssemblyFolderIdKey">
      <xs:annotation>
        <xs:documentation>
          The FoldersAssemblyFolderIdKey collects the QIF ids of all
          folders in an assembly.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:FolderAssembly"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="FoldersAssemblyFolderIdKeyref"
      refer="FoldersAssemblyFolderIdKey">
      <xs:annotation>
        <xs:documentation>
          The FoldersAssemblyFolderIdKeyref requires that Ids in
          the FolderIds of a FolderAssembly be present in the
          FoldersAssemblyFolderIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:FolderAssembly/t:FolderIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>
  </xs:element>

</xs:schema>
