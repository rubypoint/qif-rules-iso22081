            </xs:annotation>
          </xs:element>
          <xs:element name="FeatureNominalIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FeatureNominalIds element contains any feature
                nominals for the part or assembly definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FeatureZoneIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FeatureZoneIds element contains feature zones
                for the part or assembly definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CharacteristicNominalIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional CharacteristicNominalIds element contains any
                characteristic nominals for the part or assembly definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NoteIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NoteIds element contains the ids of any notes
                for the part or assembly definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NoteFlagIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional NoteFlagIds element contains the ids of
                any flag notes for the part or assembly definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PartNoteIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional PartNoteIds element contains the ids of
                any part notes for the part or assembly definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DatumDefinitionIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DatumDefinitionIds element contains any datum
                definitions for the part or assembly definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DatumTargetDefinitionIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DatumTargetDefinitionIds element contains any
                datum target definitions for the part or assembly
                definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DatumReferenceFrameIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional DatumReferenceFrameIds element contains any
                datum reference frames for the part or assembly definition.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="BodyIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional BodyIds element is an array of body
                identifiers present in this part or assembly.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CoordinateSystemIds"
                      type="ArrayReferenceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
