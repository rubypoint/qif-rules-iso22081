      <xs:extension base="DrawableBaseType">
        <xs:sequence>
          <xs:element name="Validation"
                      type="ValidationPartAssemblyType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Validation element is a set of part/assembly
                validation properties.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Header"
                      type="PartAssemblyHeaderType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional Header element is a description of the
                provenance of the file for the part or assembly.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="UUID"
                      type="UUIDChoiceType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional UUID element is a persistent identifier
                for the part or assembly definition. If a UUIDAssignment
                is used, it shall be generated using a widely accepted
                UUID generator.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ModelNumber"
                      type="xs:string"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional ModelNumber element is the identifier of a
                very specific type of part or assembly definition. There
                may be many part or assembly instances with the same
                ModelNumber, but they should all be identical (or nearly
                so).
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Version"
                      type="xs:string"
