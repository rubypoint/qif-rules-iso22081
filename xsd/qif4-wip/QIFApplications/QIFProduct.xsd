              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FeatureNominalIds"
                      type="ArrayReferenceFullType"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FeatureNominalIds element contains ids of
                feature nominals from the part or assembly for the folder.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FeatureZoneIds"
                      type="ArrayReferenceFullType"
