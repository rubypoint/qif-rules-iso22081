<xs:schema
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns="http://qifstandards.org/xsd/qif4"
  xmlns:t="http://qifstandards.org/xsd/qif4"
  targetNamespace="http://qifstandards.org/xsd/qif4"
  elementFormDefault="qualified"
  attributeFormDefault="unqualified"
  version="4devel.0.17">

  <xs:include schemaLocation="../QIFLibrary/Geometry.xsd"/>
  <xs:include schemaLocation="../QIFLibrary/Topology.xsd"/>
  <xs:include schemaLocation="../QIFLibrary/Auxiliary.xsd"/>
  <xs:include schemaLocation="../QIFLibrary/Visualization.xsd"/>
  <xs:include schemaLocation="../QIFLibrary/Traceability.xsd"/>

  <xs:annotation>
    <xs:documentation>
      This QIFProduct.xsd schema file defines definitions and instances of
      Products, Parts, and Assemblies. The file also defines many aspects
      of product geometries.
    </xs:documentation>
  </xs:annotation>

  <xs:element name="Product"
              type="ProductType">
    <xs:annotation>
      <xs:documentation>
        The global Product element describes parts and assemblies.
      </xs:documentation>
    </xs:annotation>

<!-- CONSTRAINTS (the key/keyref pairs) -->

    <xs:key name="ProductBodyIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductBodyIdKey collects all QIF ids of model bodies
          in the product.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:TopologySet/t:BodySet/t:Body"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:key name="ProductSurfaceIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductSurfaceIdKey collects all QIF ids of model surfaces
          in the product.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:GeometrySet/t:SurfaceSet/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductFaceParametricSurfaceKeyref"
      refer="ProductSurfaceIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductFaceParametricSurfaceKeyref requires that surfaces
          whose Ids are specified in model faces be present in the
          ProductSurfaceIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:TopologySet/t:FaceSet/t:Face/t:Surface/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductCurve12IdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductCurve12IdKey collects all QIF ids of model 2D curves
          in the product.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:GeometrySet/t:Curve12Set/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductLoopParametricCurve12Keyref"
      refer="ProductCurve12IdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductLoopParametricCurve12Keyref requires that 2D curves
          whose Ids are specified in model loops be present in the
          ProductCurve12IdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:TopologySet/t:LoopSet/t:Loop/t:CoEdges/t:CoEdge/t:Curve12
              /t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductCurveMeshIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductCurveMeshIdKey collects all QIF ids of model mesh
          curves in the product.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:GeometrySet/t:CurveMeshSet/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductLoopMeshCurveMeshKeyref"
      refer="ProductCurveMeshIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductLoopMeshCurveMeshKeyref requires that mesh curves
          whose Ids are specified in model loops be present in the
          ProductCurveMeshIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:TopologySet/t:LoopSet/t:LoopMesh/t:CoEdgesMesh
              /t:CoEdgeMesh/t:CurveMesh/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductEdgeIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductEdgeIdKey collects all QIF ids of edges in the EdgeSet
          of the product.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:TopologySet/t:EdgeSet/t:Edge"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductZoneSectionEdgeKeyref"
      refer="ProductEdgeIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductZoneSectionEdgeKeyref requires that certain Ids of
          Edges be present in the ProductEdgeIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:ViewSet/t:ZoneSectionSet/t:ZoneSection/t:SectionPlanes
              /t:SectionPlane/t:SectionGroups/t:SectionGroup/t:Areas/t:Area
              /t:Loops/t:Loop/t:Edges/t:Edge/t:Id
             | t:ViewSet/t:ZoneSectionSet/t:ZoneSection/t:SectionPlanes
              /t:SectionPlane/t:SectionGroups/t:SectionGroup/t:Paths/t:Path
              /t:Edges/t:Edge/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductSurfaceMeshIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductSurfaceMeshIdKey collects all QIF ids of model mesh
          surfaces.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:GeometrySet/t:SurfaceMeshSet/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductFaceMeshMeshKeyref"
      refer="ProductSurfaceMeshIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductFaceMeshMeshKeyref requires that meshes whose Ids
          are specified in model mesh faces be present in the 
          ProductSurfaceMeshIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:TopologySet/t:FaceSet/t:FaceMesh/t:Mesh/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductCurve13IdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductCurve13IdKey collects all QIF ids of model 3D curves.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:GeometrySet/t:Curve13Set/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductEdgeCurveKeyref"
      refer="ProductCurve13IdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductEdgeCurveKeyref requires that 3D curves whose Ids
          are specified in model edges be present in the
          ProductCurve13IdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:TopologySet/t:EdgeSet/t:Edge/t:Curve/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductVertexIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductVertexIdKey collects all QIF ids of model vertices.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:TopologySet/t:VertexSet/t:Vertex"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductEdgeVertexKeyref"
      refer="ProductVertexIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductEdgeVertexKeyref requires that vertices whose Ids
          are specified in model edges be present in the 
          ProductVertexIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:TopologySet/t:EdgeSet/t:Edge/t:VertexBeg/t:Id
             | t:TopologySet/t:EdgeSet/t:Edge/t:VertexEnd/t:Id
             | t:ViewSet/t:ZoneSectionSet/t:ZoneSection/t:SectionPlanes
              /t:SectionPlane/t:SectionGroups/t:SectionGroup/t:Vertices
              /t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductPointIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductPointIdKey collects all QIF ids of model 3D points.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:GeometrySet/t:PointSet/t:Point"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductVertexPointKeyref"
      refer="ProductPointIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductVertexPointKeyref requires that points whose Ids are
          specified in model vertices be present in the ProductPointIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:TopologySet/t:VertexSet/t:Vertex/t:Point/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:keyref name="ProductBodiesIdKeyref"
      refer="ProductBodyIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductBodiesIdKeyref requires that bodies whose Ids are
          specified in BodyIds be present in the ProductBodyIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:ViewSet/t:SavedViewSet/t:SavedView/t:BodyIds/t:Id
             | t:ViewSet/t:SimplifiedRepresentationSet
              /t:SimplifiedRepresentation/t:SimplifiedRepresentationGroups
              /t:SimplifiedRepresentationGroup/t:BodyIds/t:Id
             | t:ViewSet/t:ExplodedViewSet/t:ExplodedView/t:MoveGroups
              /t:MoveGroup/t:BodyIds/t:Id
             | t:ViewSet/t:DisplayStyleSet/t:DisplayStyle
              /t:DisplayStyleGroups/t:DisplayStyleGroup/t:BodyIds/t:Id
             | t:ViewSet/t:ZoneSectionSet/t:ZoneSection/t:SectionPlanes
              /t:SectionPlane/t:SectionGroups/t:SectionGroup/t:BodyId
             | t:PartSet/t:Part/t:BodyIds/t:Id
             | t:AssemblySet/t:Assembly/t:BodyIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductZoneSectionIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductZoneSectionIdKey collects all QIF ids of zone sections.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:ViewSet/t:ZoneSectionSet/t:ZoneSection"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductZoneSectionIdKeyref"
      refer="ProductZoneSectionIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductZoneSectionIdKeyref requires that Ids of zone
          sections in model saved views be present in the
          ProductZoneSectionIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:ViewSet/t:SavedViewSet/t:SavedView/t:ZoneSectionId"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ProductCoordinateSystemIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductCoordinateSystemIdKey collects all QIF ids of model
          coordinate systems.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:CoordinateSystemSet/t:CoordinateSystem"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductCoordinateSystemsIdKeyref"
      refer="ProductCoordinateSystemIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductCoordinateSystemsIdKeyref requires that Ids in
          the CoordinateSystemIds of a part or assembly be present
          in the ProductCoordinateSystemIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:PartSet/t:Part/t:CoordinateSystemIds/t:Id
             | t:AssemblySet/t:Assembly/t:CoordinateSystemIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="AuxiliaryIdKey">
      <xs:annotation>
        <xs:documentation>
          The AuxiliaryIdKey collects all QIF ids of model auxiliary
          objects.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:AuxiliarySet/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductAuxiliaryIdKeyref"
      refer="AuxiliaryIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductAuxiliaryIdKeyref requires that Ids in the
          AuxiliaryIds of a part or assembly be present in the
          AuxiliaryIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:PartSet/t:Part/t:AuxiliaryIds/t:Id
             | t:AssemblySet/t:Assembly/t:AuxiliaryIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="ViewIdKey">
      <xs:annotation>
        <xs:documentation>
          The ViewIdKey collects all QIF ids of model view objects.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:ViewSet/t:*/t:*"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductViewIdKeyref"
      refer="ViewIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductViewIdKeyref requires that Ids in the ViewIds of
          a part or assembly be present in the ViewIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:PartSet/t:Part/t:ViewIds/t:Id
             | t:AssemblySet/t:Assembly/t:ViewIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="PointCloudIdKey">
      <xs:annotation>
        <xs:documentation>
          The PointCloudIdKey collects all QIF ids of model point cloud
          objects.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:TopologySet/t:PointCloudSet/t:PointCloud"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductPointCloudIdKeyref"
      refer="PointCloudIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductPointCloudIdKeyref requires that Ids in the
          PointCloudsIds of a part or assembly be present
          in the PointCloudIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:PartSet/t:Part/t:PointCloudIds/t:Id
             | t:AssemblySet/t:Assembly/t:PointCloudIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="PartNoteIdKey">
      <xs:annotation>
        <xs:documentation>
          The PartNoteIdKey collects the QIF ids of all part notes
          in the product.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:PartNoteSet/t:PartNote"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="ProductPartNoteKeyref"
      refer="PartNoteIdKey">
      <xs:annotation>
        <xs:documentation>
          The ProductPartNoteKeyref requires that Ids in the PartNoteIds
          of a part, assembly, or part note be present
          in the PartNoteIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:PartSet/t:Part/t:PartNoteIds/t:Id
             | t:AssemblySet/t:Assembly/t:PartNoteIds/t:Id
             | t:PartNoteSet/t:PartNote/t:PartNoteIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="NoteFlagIdKey">
      <xs:annotation>
        <xs:documentation>
          The NoteFlagIdKey collects the QIF ids of all flag notes in
          the product.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:NoteFlagSet/t:NoteFlag"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="NoteFlagKeyref"
      refer="NoteFlagIdKey">
      <xs:annotation>
        <xs:documentation>
          The NoteFlagKeyref requires that Ids in the FlagNoteIds
          of a part or assembly be present in the NoteFlagIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:PartSet/t:Part/t:NoteFlagIds/t:Id
             | t:AssemblySet/t:Assembly/t:NoteFlagIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>

    <xs:key name="NoteIdKey">
      <xs:annotation>
        <xs:documentation>
          The NoteIdKey collects the QIF ids of all standard notes
          in the product.
        </xs:documentation>
      </xs:annotation>
      <xs:selector xpath="t:NoteSet/t:Note"/>
      <xs:field xpath="@id"/>
    </xs:key>

    <xs:keyref name="NoteIdKeyref"
      refer="NoteIdKey">
      <xs:annotation>
        <xs:documentation>
          The NoteIdKeyref requires that Ids in the NoteIds
          of a part or assembly be present in the NoteIdKey.
        </xs:documentation>
      </xs:annotation>
      <xs:selector
        xpath="t:PartSet/t:Part/t:NoteIds/t:Id
             | t:AssemblySet/t:Assembly/t:NoteIds/t:Id"/>
      <xs:field xpath="."/>
    </xs:keyref>
  </xs:element>

  <xs:complexType name="ProductType">
    <xs:annotation>
      <xs:documentation>
        The ProductType defines a top-level product, which shall itself
        be a part or assembly.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Header"
                  type="ProductHeaderType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Header element gives information about the
            provenance of the Product data set.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="GeometrySet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional GeometrySet element is a collection of all
            geometric entities present in the product, divided by type
            in a number of sub-sets.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="TopologySet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional TopologySet element is a collection of all
            topological entities present in the product, divided by type
            in a number of sub-sets.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="NoteSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NoteSet element is a collection of all
            notes present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="NoteFlagSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional NoteFlagSet element is a collection of all
            flag notes present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="PartNoteSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional PartNoteSet element is a collection of all
            part notes and standard notes present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="ViewSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ViewSet element is a collection of all views
            present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="LayerSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional LayerSet element is a collection of all model
            layers.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="CoordinateSystemSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional CoordinateSystemSet element is a collection of all
            coordinate systems present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="VisualizationSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional VisualizationSet element is a collection of
            display information objects associated with PMI entities.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="AuxiliarySet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AuxiliarySet element is a collection of all
            auxiliary objects present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="PartSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional PartSet element is a collection of all
            parts present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="AssemblySet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AssemblySet element is a collection of all
            assemblies present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="ComponentSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ComponentSet element is a collection of all
            components present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:choice minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            This optional compositor provides a choice among a part,
            an assembly, and a component as the root of the product.
          </xs:documentation>
        </xs:annotation>
        <xs:element name="RootPart"
                    type="ElementReferenceType">
          <xs:annotation>
            <xs:documentation>
              The RootPart element is the root of the product.
            </xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="RootAssembly"
                    type="ElementReferenceType">
          <xs:annotation>
            <xs:documentation>
              The RootAssembly element is the root of the product.
            </xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="RootComponent"
                    type="ElementReferenceType">
          <xs:annotation>
            <xs:documentation>
              The RootComponent element is the root of the product.
            </xs:documentation>
          </xs:annotation>
        </xs:element>
      </xs:choice>
      <xs:element ref="AsmPaths"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AsmPaths element is a collection of all parts
            present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="AppearanceSet"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional AppearanceSet element is a collection of
            appearances present in the product.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MaterialLibrary"
                  type="MaterialsType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional MaterialLibrary element is a list of the materials
            from which the actual product is fabricated.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="AsmPathType">
    <xs:annotation>
      <xs:documentation>
        The AsmPathType defines information about assembly path, this path
        is used for identification of an object inside an assembly.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ComponentIds"
                  type="ArrayReferenceType"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional ComponentIds element is an array of
            identifiers of the scene components which contain this
            entity. This array shows the "path" from the root to the
            parent component. The id of the parent component shall be
            the last element of this array.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="Attributes"
                  minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            The optional Attributes element contains user defined
            attributes (typified, binary array, or XML structured).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="id"
                  type="QIFIdType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required id attribute is the QIF id of the assembly path,
          used for referencing.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="AsmPathsType">
    <xs:annotation>
      <xs:documentation>
        The AsmPathsType defines a list of one or more assembly paths.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="AsmPath"
                  type="AsmPathType"
                  maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Each AsmPath element is an assembly path in the list.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="n"
                  type="NaturalType"
                  use="required">
      <xs:annotation>
        <xs:documentation>
          The required n attribute is the number of assembly paths in this
          set.
