                the part that is useful for inspection planning.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element ref="FoldersPart"
                      minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                The optional FoldersPart element is a folders tree in
                the part.
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="FoldersPartType">
