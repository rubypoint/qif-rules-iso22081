  <xs:complexType name="PartAssemblyBaseType"
                  abstract="true">
    <xs:annotation>
      <xs:documentation>
        The abstract PartAssemblyBaseType is the base type that defines
        information about a part or assembly definition that was inspected
        or will be inspected.
